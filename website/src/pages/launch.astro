---
import Layout from "@/components/layout/Layout.astro";
import { organizationJsonLd } from "@/constants/default-jsonld";
import { getLocaleFromUrl, createTranslator } from "@/utils/i18n";
import { createMetadata } from "@/utils/create-metadata";
import AllocationChart from "@/components/features/launch/AllocationChart.astro";
import VestingLockups from "@/components/features/launch/VestingLockups.astro";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const metadata = createMetadata({
  title: t("launch.meta.title"),
  description: t("launch.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = {
  "@context": "https://schema.org",
  ...(organizationJsonLd as any),
};

// Helper to render text with **bold** markdown
function renderMarkdown(text: string) {
  return text.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
}

// TGE allocation data
const tgeData = [
  {
    category: t("launch.tge.table.private_sale"),
    percent: "15%",
    quan: "3,150,000",
  },
  {
    category: t("launch.tge.table.public_sale"),
    percent: "10%",
    quan: "2,100,000",
  },
  {
    category: t("launch.tge.table.dex_liquidity"),
    percent: "10%",
    quan: "2,100,000",
  },
  { category: t("launch.tge.table.total"), percent: "35%", quan: "7,350,000" },
];

// Mining distribution data
const miningData = [
  { recipient: t("launch.mining.table.miners"), percent: "50%" },
  { recipient: t("launch.mining.table.company"), percent: "15%" },
];

// Company alignment points
const companyPoints = t("launch.company.points") as unknown as string[];
---

<Layout {...metadata} jsonLd={jsonLd}>
  <section
    class="max-w-content mx-auto px-[30px] py-10 lg:pt-[120px] lg:pb-20 2xl:px-0"
  >
    <div class="mx-auto max-w-3xl">
      <!-- Title -->
      <h1 class="font-small-title lg:font-medium-title mb-10">
        {t("launch.title")}
      </h1>

      <!-- Overview -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.overview.title")}</h2>
        <p
          class="font-body-mobile lg:font-body"
          set:html={renderMarkdown(t("launch.overview.content"))}
        />
      </div>

      <!-- Token Supply -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.supply.title")}</h2>
        <ul class="font-body-mobile lg:font-body mb-4 list-none space-y-2">
          <li>
            <strong>{t("launch.supply.max_supply")}</strong>
            {t("launch.supply.max_supply_value")}
          </li>
          <li>
            <strong>{t("launch.supply.tge_supply")}</strong>
            {t("launch.supply.tge_supply_value")}
          </li>
          <li>
            <strong>{t("launch.supply.mining_supply")}</strong>
            {t("launch.supply.mining_supply_value")}
          </li>
        </ul>
        <p class="font-body-mobile lg:font-body text-quantus-white/70">
          {t("launch.supply.note")}
        </p>
      </div>

      <!-- Chart -->
      <AllocationChart />

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Launch Allocation (TGE) -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.tge.title")}</h2>
        <p class="font-body-mobile lg:font-body mb-4">
          {t("launch.tge.intro")}
        </p>

        <div class="mb-4 overflow-x-auto">
          <table class="font-body-mobile lg:font-body w-full border-collapse">
            <thead>
              <tr class="border-quantus-white/20 border-b">
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.tge.table.category")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.tge.table.percent")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.tge.table.quan")}</th
                >
              </tr>
            </thead>
            <tbody>
              {
                tgeData.map((row, i) => (
                  <tr
                    class:list={[
                      "border-quantus-white/10 border-b",
                      i === tgeData.length - 1 && "font-bold",
                    ]}
                  >
                    <td class="px-4 py-3">{row.category}</td>
                    <td class="px-4 py-3">{row.percent}</td>
                    <td class="px-4 py-3">{row.quan}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <p class="font-body-mobile lg:font-body mb-4">
          {t("launch.tge.note_1")}
        </p>
        <p class="font-body-mobile lg:font-body">
          {t("launch.tge.note_2")}
        </p>
      </div>

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Mining-Based Distribution -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.mining.title")}</h2>
        <p
          class="font-body-mobile lg:font-body mb-4"
          set:html={renderMarkdown(t("launch.mining.intro"))}
        />
        <p class="font-body-mobile lg:font-body mb-4 font-bold">
          {t("launch.mining.ownership_title")}
        </p>

        <div class="mb-4 overflow-x-auto">
          <table class="font-body-mobile lg:font-body w-full border-collapse">
            <thead>
              <tr class="border-quantus-white/20 border-b">
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.mining.table.recipient")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.mining.table.percent")}</th
                >
              </tr>
            </thead>
            <tbody>
              {
                miningData.map((row) => (
                  <tr class="border-quantus-white/10 border-b">
                    <td class="px-4 py-3">{row.recipient}</td>
                    <td class="px-4 py-3">{row.percent}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Company Alignment -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.company.title")}</h2>
        <p class="font-body-mobile lg:font-body mb-2">
          {t("launch.company.intro")}
        </p>
        <p class="font-body-mobile lg:font-body mb-4">
          {t("launch.company.content")}
        </p>
        <ul class="font-body-mobile lg:font-body list-disc space-y-2 pl-6">
          {
            companyPoints.map((point) => (
              <li set:html={renderMarkdown(point)} />
            ))
          }
        </ul>
      </div>

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Lockups & Vesting -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.vesting.title")}</h2>
        <VestingLockups t={t} />
        <p class="font-body-mobile lg:font-body text-quantus-white/70">
          {t("launch.vesting_summary")}
        </p>
      </div>

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Fees & Burning -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.fees.title")}</h2>
        <p
          class="font-body-mobile lg:font-body mb-4"
          set:html={renderMarkdown(t("launch.fees.intro"))}
        />
        <ul class="font-body-mobile lg:font-body mb-4 list-disc space-y-2 pl-6">
          {
            (t("launch.fees.points") as unknown as string[]).map((point) => (
              <li set:html={renderMarkdown(point)} />
            ))
          }
        </ul>
        <p class="font-body-mobile lg:font-body text-quantus-white/70">
          {t("launch.fees.note")}
        </p>
      </div>

      <hr class="border-quantus-white/10 mt-0 mb-10" />

      <!-- Funding History -->
      <div class="mb-10">
        <h2 class="font-small-title mb-4">{t("launch.funding.title")}</h2>
        <p class="font-body-mobile lg:font-body mb-4">
          {t("launch.funding.intro")}
        </p>
        <div class="overflow-x-auto">
          <table class="font-body-mobile lg:font-body w-full border-collapse">
            <thead>
              <tr class="border-quantus-white/20 border-b">
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.funding.table.round")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.funding.table.raised")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.funding.table.valuation")}</th
                >
                <th class="px-4 py-3 text-left font-bold"
                  >{t("launch.funding.table.lead")}</th
                >
              </tr>
            </thead>
            <tbody>
              <tr class="border-quantus-white/10 border-b">
                <td class="px-4 py-3">{t("launch.funding.table.pr1")}</td>
                <td class="px-4 py-3">{t("launch.funding.table.raised_pr1")}</td
                >
                <td class="px-4 py-3">{t("launch.funding.table.val_pr1")}</td>
                <td class="px-4 py-3">{t("launch.funding.table.dash")}</td>
              </tr>
              <tr class="border-quantus-white/10 border-b">
                <td class="px-4 py-3">{t("launch.funding.table.pr2")}</td>
                <td class="px-4 py-3">{t("launch.funding.table.raised_pr2")}</td
                >
                <td class="px-4 py-3">{t("launch.funding.table.val_pr2")}</td>
                <td class="px-4 py-3">{t("launch.funding.table.lead_pr2")}</td>
              </tr>
              <tr class="border-quantus-white/20 border-t font-bold">
                <td class="px-4 py-3">{t("launch.funding.table.total")}</td>
                <td class="px-4 py-3"
                  >{t("launch.funding.table.raised_total")}</td
                >
                <td class="px-4 py-3"></td>
                <td class="px-4 py-3"></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>
