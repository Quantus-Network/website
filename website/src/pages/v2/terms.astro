---
import "@/v2/styles/terms-and-privacy.css";

import Layout from "@/v2/components/layout/Layout.astro";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";
import { createMetadata } from "@/utils/create-metadata";
import { JsonLdGraph } from "@/utils/build-json-ld";
import {
  androidAppJsonLd,
  iosAppJsonLd,
  organizationJsonLd,
  websiteJsonLd,
} from "@/constants/default-jsonld";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const metadata = createMetadata({
  title: t("v2.terms.meta.title"),
  description: t("v2.terms.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = JsonLdGraph({
  "@context": "https://schema.org",
  "@graph": [websiteJsonLd, organizationJsonLd, iosAppJsonLd, androidAppJsonLd],
});
---

<Layout {...metadata} jsonLd={jsonLd}>
  <section id="policy-hero">
    <span class="policy-eyebrow">
      {t("v2.terms.hero.eyebrow")}
    </span>
    <h1 class="policy-h1">
      {t("v2.terms.hero.title")}
    </h1>
    <span class="policy-meta">
      {t("v2.terms.hero.last_updated")}
    </span>
    <div class="policy-divider"></div>
  </section>

  <section id="policy-content">
    <span class="policy-sub-h3">
      {t("v2.terms.what_we_provide.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.what_we_provide.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("v2.terms.what_we_provide.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.what_you_cannot_do.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.what_you_cannot_do.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("v2.terms.what_you_cannot_do.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.mining_participation.title")}
    </span>

    <ul class="policy-list">
      {
        (t("v2.terms.mining_participation.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.dispute_resolution.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.dispute_resolution.content")}
    </p>

    <span class="policy-sub-h3">
      {t("v2.terms.your_responsibilities.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.your_responsibilities.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("v2.terms.your_responsibilities.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.non_custodial.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.non_custodial.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("v2.terms.non_custodial.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.disclaimers.title")}
    </span>

    <p class="policy-body">
      {t("v2.terms.disclaimers.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("v2.terms.disclaimers.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("v2.terms.contact.title")}
    </span>

    <p class="policy-body">
      {(t("v2.terms.contact.address") as string).split("\n").map((line, idx) => (
        <>
          {line}
          {idx < (t("v2.terms.contact.address") as string).split("\n").length - 1 && <br />}
        </>
      ))}
    </p>
    <p class="policy-body">
      {t("v2.terms.contact.note")}{" "}
      <a
        href={`mailto:${t("v2.terms.contact.email")}`}
        style="color:#FF6B35;text-decoration:none;"
      >
        {t("v2.terms.contact.email")}
      </a>
    </p>
  </section>
</Layout>
