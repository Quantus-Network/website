---
import { render } from "astro:content";
import Layout from "@/components/layout/Layout.astro";
import {
  getLocaleFromUrl,
  createTranslator,
  SUPPORTED_LOCALES,
} from "@/utils/i18n";
import { JsonLdGraph } from "@/utils/build-json-ld";
import { getWhitepaperJsonLd } from "@/constants/default-jsonld";
import { createMetadata } from "@/utils/create-metadata";
import WhitepaperHeader from "@/components/features/whitepaper/WhitepaperHeader.astro";
import TableOfContents from "@/components/features/whitepaper/TableOfContents.astro";
import WhitepaperContent from "@/components/features/whitepaper/WhitepaperContent.astro";
import {
  getLatestWhitepaper,
  getWhitepapersForLocale,
  getAllVersions,
  getWhitepaperPdfPath,
  resolveWhitepaperTocHeadings,
} from "@/utils/whitepaper";
import WhitepaperPrintCover from "@/components/features/whitepaper/WhitepaperPrintCover.astro";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const entry = await getLatestWhitepaper(locale);
if (!entry) return Astro.redirect("/404");

const allEntries = await getWhitepapersForLocale(locale);
const versions = getAllVersions(allEntries);
const latestVersion =
  versions[versions.length - 1]?.version ?? entry.data.version;
const pdfHref = getWhitepaperPdfPath(locale, entry.data.version);

const { Content, headings: renderHeadings } = await render(entry);
const headings = resolveWhitepaperTocHeadings(entry, renderHeadings);

const metadata = createMetadata({
  title: t("whitepaper.meta.title"),
  description: t("whitepaper.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = JsonLdGraph({
  "@context": "https://schema.org",
  "@graph": [getWhitepaperJsonLd(locale, entry.data.version)],
});

const styleVersion = entry.data.version === "0.3.1" ? "v1" : "v2";
---

<Layout {...metadata} jsonLd={jsonLd}>
  <section
    id="whitepaper-section"
    class:list={[
      "lg:max-w-content px-content-edges-mobile mx-auto pt-30 pb-10 lg:pb-20 2xl:px-0",
    ]}
  >
    {
      entry.data.pdfCover && (
        <WhitepaperPrintCover
          version={entry.data.version}
          publishedDate={entry.data.publishedDate}
          updatedDate={entry.data.updatedDate}
          locale={locale}
          t={t}
        />
      )
    }

    <WhitepaperHeader
      title={entry.data.title}
      version={entry.data.version}
      latestVersion={latestVersion}
      versions={versions}
      updatedDate={entry.data.updatedDate}
      publishedDate={entry.data.publishedDate}
      authors={entry.data.authors}
      pdfHref={pdfHref}
      locale={locale}
      t={t}
    />

    <TableOfContents
      headings={headings}
      tocLabel={t("whitepaper.on_this_page")}
      backToTopLabel={t("whitepaper.back_to_top")}
      variant="mobile"
    />

    <div class="lg:flex lg:gap-14">
      <div class="min-w-0 flex-1">
        <WhitepaperContent styleVersion={styleVersion}>
          <Content />
        </WhitepaperContent>
      </div>

      <div class="hidden w-[260px] shrink-0 lg:block">
        <TableOfContents
          headings={headings}
          tocLabel={t("whitepaper.on_this_page")}
          backToTopLabel={t("whitepaper.back_to_top")}
          variant="desktop"
        />
      </div>
    </div>

    {
      entry.data.changelog.length > 0 && (
        <div class="mt-16 border-t border-white/10 pt-8 print:border-black/10">
          <h2 class="mb-4 text-lg font-semibold text-white/80 print:text-black/80">
            {t("whitepaper.changelog")}
          </h2>
          <ul class="space-y-2">
            {entry.data.changelog.map((item) => (
              <li class="flex items-start gap-2 text-sm text-white/60 print:text-black/60">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-white/30 print:bg-black/40" />
                {item}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</Layout>

<script>
  function initTocHighlighting() {
    const tocLinks = document.querySelectorAll(
      "[data-toc-desktop] [data-toc-link]",
    );
    if (tocLinks.length === 0) return;

    const headingElements: Element[] = [];
    tocLinks.forEach((link) => {
      const slug = (link as HTMLElement).dataset.headingSlug;
      if (slug) {
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    if (headingElements.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((link) => {
              const slug = (link as HTMLElement).dataset.headingSlug;
              if (slug === id) {
                link.classList.add("!border-whitepaper-primary", "!text-white");
              } else {
                link.classList.remove(
                  "!border-whitepaper-primary",
                  "!text-white",
                );
              }
            });
          }
        }
      },
      { rootMargin: "-80px 0px -65% 0px", threshold: 0 },
    );

    headingElements.forEach((el) => observer.observe(el));
  }
  initTocHighlighting();
  document.addEventListener("astro:after-swap", initTocHighlighting);
</script>

<script>
  const params = new URLSearchParams(window.location.search);
  const isPrint = params.get("print") === "true";

  if (isPrint)
    document.getElementById("whitepaper-section")?.classList.add("print-mode");
</script>
