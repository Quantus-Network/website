---
import "@/styles/terms-and-privacy.css";

import Layout from "@/components/layout/Layout.astro";
import {
  createTranslator,
  getLocaleFromUrl,
  SUPPORTED_LOCALES,
} from "@/utils/i18n";
import { createMetadata } from "@/utils/create-metadata";
import { JsonLdGraph } from "@/utils/build-json-ld";
import {
  androidAppJsonLd,
  iosAppJsonLd,
  organizationJsonLd,
  websiteJsonLd,
} from "@/constants/default-jsonld";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const metadata = createMetadata({
  title: t("terms.meta.title"),
  description: t("terms.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = JsonLdGraph({
  "@context": "https://schema.org",
  "@graph": [websiteJsonLd, organizationJsonLd, iosAppJsonLd, androidAppJsonLd],
});
---

<Layout {...metadata} jsonLd={jsonLd}>
  <section id="policy-hero">
    <span class="policy-eyebrow">
      {t("terms.hero.eyebrow")}
    </span>
    <h1 class="policy-h1">
      {t("terms.hero.title")}
    </h1>
    <span class="policy-meta">
      {t("terms.hero.last_updated")}
    </span>
    <div class="policy-divider"></div>
  </section>

  <section id="policy-content">
    <span class="policy-sub-h3">
      {t("terms.what_we_provide.title")}
    </span>

    <p class="policy-body">
      {t("terms.what_we_provide.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("terms.what_we_provide.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.what_you_cannot_do.title")}
    </span>

    <p class="policy-body">
      {t("terms.what_you_cannot_do.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("terms.what_you_cannot_do.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.mining_participation.title")}
    </span>

    <ul class="policy-list">
      {
        (t("terms.mining_participation.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.dispute_resolution.title")}
    </span>

    <p class="policy-body">
      {t("terms.dispute_resolution.content")}
    </p>

    <span class="policy-sub-h3">
      {t("terms.your_responsibilities.title")}
    </span>

    <p class="policy-body">
      {t("terms.your_responsibilities.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("terms.your_responsibilities.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.non_custodial.title")}
    </span>

    <p class="policy-body">
      {t("terms.non_custodial.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("terms.non_custodial.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.disclaimers.title")}
    </span>

    <p class="policy-body">
      {t("terms.disclaimers.intro")}
    </p>
    <ul class="policy-list">
      {
        (t("terms.disclaimers.items") as string[]).map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>

    <span class="policy-sub-h3">
      {t("terms.contact.title")}
    </span>

    <p class="policy-body">
      {
        (t("terms.contact.address") as string).split("\n").map((line, idx) => (
          <>
            {line}
            {idx <
              (t("terms.contact.address") as string).split("\n").length - 1 && (
              <br />
            )}
          </>
        ))
      }
    </p>
    <p class="policy-body">
      {t("terms.contact.note")}{" "}
      <a
        href={`mailto:${t("terms.contact.email")}`}
        style="color:#FF6B35;text-decoration:none;"
      >
        {t("terms.contact.email")}
      </a>
    </p>
  </section>
</Layout>
