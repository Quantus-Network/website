---
import Layout from "@/components/layout/Layout.astro";
import {
  createTranslator,
  getLocaleFromUrl,
  SUPPORTED_LOCALES,
} from "@/utils/i18n";
import { createMetadata } from "@/utils/create-metadata";
import { JsonLdGraph } from "@/utils/build-json-ld";
import {
  androidAppJsonLd,
  iosAppJsonLd,
  organizationJsonLd,
  websiteJsonLd,
} from "@/constants/default-jsonld";
import HeroBanner from "@/components/features/qday-checker/HeroBanner.astro";
import DefinitionSection from "@/components/features/qday-checker/DefinitionSection.astro";
import MethodSection from "@/components/features/qday-checker/MethodSection.astro";
import AdviceSection from "@/components/features/qday-checker/AdviceSection.astro";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const metadata = createMetadata({
  title: t("quantum_risk_checker.meta.title"),
  description: t("quantum_risk_checker.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = JsonLdGraph({
  "@context": "https://schema.org",
  "@graph": [websiteJsonLd, organizationJsonLd, iosAppJsonLd, androidAppJsonLd],
});
---

<Layout {...metadata} jsonLd={jsonLd}>
  <HeroBanner />
  <DefinitionSection />
  <MethodSection />
  <AdviceSection />
</Layout>
