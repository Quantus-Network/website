---
import Layout from "@/components/layout/Layout.astro";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";
import { createMetadata } from "@/utils/create-metadata";
import { JsonLdGraph } from "@/utils/build-json-ld";
import {
  androidAppJsonLd,
  iosAppJsonLd,
  organizationJsonLd,
  websiteJsonLd,
} from "@/constants/default-jsonld";
import HeroBanner from "@/components/features/wallet/HeroBanner.astro";
import AdvantagesSection from "@/components/features/wallet/AdvantagesSection.astro";
import FeaturesSection from "@/components/features/wallet/FeaturesSection.astro";
import IssuesSection from "@/components/features/wallet/IssuesSection.astro";
import CtaSection from "@/components/features/wallet/CtaSection.astro";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const metadata = createMetadata({
  title: t("wallet.meta.title"),
  description: t("wallet.meta.description"),
  pathname: Astro.url.pathname,
});

const jsonLd = JsonLdGraph({
  "@context": "https://schema.org",
  "@graph": [websiteJsonLd, organizationJsonLd, iosAppJsonLd, androidAppJsonLd],
});
---

<Layout {...metadata} jsonLd={jsonLd}>
  <HeroBanner />
  <AdvantagesSection />
  <FeaturesSection />
  <IssuesSection />
  <CtaSection />
</Layout>
