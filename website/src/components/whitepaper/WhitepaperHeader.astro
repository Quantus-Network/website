---
import type { Locale } from "@/utils/i18n";
import { formatDate } from "@/utils/i18n";
import VersionSelector from "./VersionSelector.astro";
import DownloadButton from "./DownloadButton.astro";

export interface Props {
  title: string;
  version: string;
  latestVersion: string;
  versions: { version: string; date: Date }[];
  updatedDate?: Date;
  publishedDate: Date;
  authors: string[];
  abstract: string;
  pdfHref: string;
  locale: Locale;
  t: (key: string) => string;
}

const {
  title,
  version,
  latestVersion,
  versions,
  updatedDate,
  publishedDate,
  authors,
  abstract,
  pdfHref,
  locale,
  t,
} = Astro.props;

const displayDate = updatedDate ?? publishedDate;
---

<header class="mb-10 border-b border-white/10 pb-10 print:border-black/10" id="top">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-small-title lg:font-medium-title mb-3 text-white print:text-black">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-white/50 print:text-black/50">
        <span>{t("whitepaper.authors")}: {authors.join(", ")}</span>
        <span class="text-white/20">|</span>
        <span>
          {t("whitepaper.last_updated")}: {formatDate(displayDate, locale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </span>
      </div>
    </div>

    <div class="flex items-center gap-3 print:hidden">
      {versions.length > 1 && (
        <VersionSelector
          versions={versions}
          currentVersion={version}
          locale={locale}
          latestVersion={latestVersion}
          t={t}
        />
      )}
      <DownloadButton href={pdfHref} label={t("whitepaper.download_pdf")} />
    </div>
  </div>

  <p class="max-w-3xl text-base leading-relaxed text-white/60 print:text-black/60">
    <span class="font-semibold text-white/80 print:text-black/80">{t("whitepaper.abstract")}:</span>{" "}
    {abstract}
  </p>
</header>
