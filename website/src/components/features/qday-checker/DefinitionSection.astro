---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="what-qday">
  <div class="qrc-divider"></div>
  <div class="qrc-section-inner">
    <span class="qrc-eyebrow qrc-animate" data-delay="0">
      {t("quantum_risk_checker.definition.eyebrow")}
    </span>
    <h2
      class="qrc-h2 qrc-animate"
      data-delay="0.15"
      style="font-size:clamp(28px,3.2vw,48px);"
    >
      {t("quantum_risk_checker.definition.title")}
    </h2>
    <p class="qrc-body qrc-animate" data-delay="0.3" style="margin-top:28px;">
      {t("quantum_risk_checker.definition.body_1")}
    </p>
    <p class="qrc-body qrc-animate" data-delay="0.4" style="margin-top:20px;">
      {t("quantum_risk_checker.definition.body_2")}
    </p>
  </div>
</section>

<style>
  #what-qday {
    background: #0e0e0e;
  }

  .qrc-body {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(232, 230, 224, 0.65);
    max-width: 100%;
  }

  @media (max-width: 768px) {
    #what-qday h2 {
      white-space: normal;
      font-size: clamp(24px, 5vw, 36px);
    }
  }
</style>
