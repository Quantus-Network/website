---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="after-report">
  <div class="qrc-divider"></div>
  <div class="qrc-section-inner">
    <span class="qrc-eyebrow qrc-animate" data-delay="0">
      {t("quantum_risk_checker.advice.eyebrow")}
    </span>
    <h2
      class="qrc-h2 qrc-animate"
      data-delay="0.15"
      style="max-width:640px;margin-top:16px;"
    >
      {t("quantum_risk_checker.advice.title_line1")}<br />{
        t("quantum_risk_checker.advice.title_line2")
      }
    </h2>
    <p
      class="qrc-body qrc-animate"
      data-delay="0.3"
      style="max-width:560px;margin-top:24px;"
    >
      {t("quantum_risk_checker.advice.body")}
    </p>
    <a
      href="#"
      class="qrc-cta-btn qrc-animate wallet-cta-link"
      data-delay="0.45"
      target="_blank"
      rel="noopener">{t("quantum_risk_checker.advice.cta")}</a
    >
    <span class="qrc-footer-note qrc-animate" data-delay="0.6">
      {t("quantum_risk_checker.advice.footer_note")}
    </span>
  </div>
</section>

<style>
  #after-report {
    background: #0e0e0e;
  }

  #after-report .qrc-section-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .qrc-cta-btn {
    display: inline-block;
    margin-top: 40px;
    background: #ff6b35;
    color: #0e0e0e;
    font-family: "Geist Mono", monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 14px 36px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .qrc-cta-btn:hover {
    opacity: 0.88;
  }

  .qrc-footer-note {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.2);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin-top: 48px;
  }
</style>
