---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="how-it-works">
  <div class="qrc-divider"></div>
  <div class="qrc-section-inner">
    <span class="qrc-eyebrow qrc-animate" data-delay="0">
      {t("quantum_risk_checker.method.eyebrow")}
    </span>
    <h2 class="qrc-h2 qrc-animate" data-delay="0.1" style="margin-top:16px;">
      {t("quantum_risk_checker.method.title")}
    </h2>
    <p class="qrc-intro qrc-animate" data-delay="0.2">
      {t("quantum_risk_checker.method.intro")}
    </p>

    <div class="qrc-signal-grid">
      <div class="qrc-signal-card qrc-animate" data-delay="0.1">
        <span class="qrc-signal-title">
          {t("quantum_risk_checker.method.signal_1_title")}
        </span>
        <p class="qrc-signal-body">
          {t("quantum_risk_checker.method.signal_1_body")}
        </p>
      </div>
      <div class="qrc-signal-card qrc-animate" data-delay="0.2">
        <span class="qrc-signal-title">
          {t("quantum_risk_checker.method.signal_2_title")}
        </span>
        <p class="qrc-signal-body">
          {t("quantum_risk_checker.method.signal_2_body")}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  #how-it-works {
    background: #0e0e0e;
  }

  .qrc-intro {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    color: rgba(232, 230, 224, 0.65);
    max-width: 600px;
    margin-top: 16px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .qrc-signal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(232, 230, 224, 0.08);
    margin-bottom: 48px;
  }

  .qrc-signal-card {
    background: #0e0e0e;
    padding: 40px 36px;
  }

  .qrc-signal-title {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: #ff6b35;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    display: block;
    margin-bottom: 16px;
  }

  .qrc-signal-body {
    font-family: "Geist", sans-serif;
    font-size: 15px;
    color: rgba(232, 230, 224, 0.65);
    line-height: 1.7;
  }

  .qrc-report-label {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    display: block;
    margin-bottom: 16px;
  }

  .qrc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .qrc-pill {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.55);
    border: 1px solid rgba(232, 230, 224, 0.12);
    padding: 7px 18px;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .qrc-signal-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
