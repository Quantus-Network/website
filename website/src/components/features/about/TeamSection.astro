          <span class="team-role">CEO and CTO</span>
          <a
            href="https://x.com/YuviLightman"
            target="_blank"
            rel="noopener"
            class="team-x-link"
          >
            <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"
