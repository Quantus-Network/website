---
import { getCollection } from "astro:content";
import {
  createTranslator,
  getLocaleFromUrl,
  getLocalizedPath,
  DEFAULT_LOCALE,
} from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

let localePosts = await getCollection("blog", ({ id }) => {
  return id.toLowerCase().startsWith(`${locale.toLowerCase()}/`);
});
if (localePosts.length === 0) {
  localePosts = await getCollection("blog", ({ id }) => {
    return id.toLowerCase().startsWith(`${DEFAULT_LOCALE.toLowerCase()}/`);
  });
}

const recentPosts = localePosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const translations = await import(`../../../i18n/${locale}.json`);
const tagsMap: Record<string, string> = translations.default.blog?.tags ?? {};

function formatDate(date: Date): string {
  return date
    .toLocaleDateString("en-US", { month: "short", day: "2-digit" })
    .toUpperCase();
}

function getTagLabel(tag: string): string {
  return (tagsMap[tag] ?? tag.replace(/-/g, " ")).toUpperCase();
}

function getBlogUrl(postId: string): string {
  const slug = postId.split("/").slice(1).join("/");
  return getLocalizedPath(locale, `/blog/${slug}`);
}
---

<section id="comm-blog">
  <div class="comm-divider"></div>
  <div class="comm-section-inner">
    <span class="comm-eyebrow comm-animate" data-delay="0">
      {t("community.blog.eyebrow")}
    </span>
    <h2 class="comm-blog-h2 comm-animate" data-delay="0.1">
      {t("community.blog.heading")}
    </h2>
    <p class="comm-blog-sub comm-animate" data-delay="0.2">
      {t("community.blog.sub")}
    </p>

    {
      recentPosts.map((post, i) => (
        <a
          href={getBlogUrl(post.id)}
          class="comm-blog-row comm-animate"
          data-delay={String(i * 0.1)}
        >
          <div class="comm-blog-row-left">
            <div class="comm-blog-row-top">
              <span class="comm-blog-date">{formatDate(post.data.pubDate)}</span>
              <span class="comm-blog-tag">{getTagLabel(post.data.tags[0] ?? "")}</span>
            </div>
            <span class="comm-blog-title">{post.data.title}</span>
          </div>
          <span class="comm-blog-arrow">→</span>
        </a>
      ))
    }

    <a
      href={getLocalizedPath(locale, "/blog")}
      class="comm-blog-view-all comm-animate"
      data-delay="0.3">{t("community.blog.view_all")}</a
    >
  </div>
</section>

<style>
  #comm-blog {
    background: #0e0e0e;
  }

  .comm-blog-h2 {
    font-family: "Geist", sans-serif;
    font-size: 48px;
    font-weight: 500;
    color: #ffffff;
    margin-top: 16px;
    margin-bottom: 0;
  }

  .comm-blog-sub {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    color: rgba(232, 230, 224, 0.6);
    margin-top: 16px;
    margin-bottom: 48px;
    max-width: 520px;
  }

  .comm-blog-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    border-bottom: 1px solid rgba(232, 230, 224, 0.08);
    text-decoration: none;
    cursor: pointer;
    transition: padding-left 0.2s ease;
  }
  .comm-blog-row:first-of-type {
    border-top: 1px solid rgba(232, 230, 224, 0.08);
  }
  .comm-blog-row:hover {
    padding-left: 8px;
  }

  .comm-blog-row-left {
    flex: 1;
  }

  .comm-blog-row-top {
    display: flex;
    align-items: center;
  }

  .comm-blog-date {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .comm-blog-tag {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    text-transform: uppercase;
    padding: 2px 10px;
    border: 1px solid rgba(232, 230, 224, 0.12);
    color: rgba(232, 230, 224, 0.45);
    margin-left: 12px;
  }

  .comm-blog-title {
    font-family: "Geist", sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: rgba(232, 230, 224, 0.9);
    margin-top: 8px;
    display: block;
  }

  .comm-blog-arrow {
    font-size: 18px;
    color: #ff6b35;
    flex-shrink: 0;
    margin-left: 24px;
  }

  .comm-blog-view-all {
    display: block;
    margin-top: 32px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: #ff6b35;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .comm-blog-view-all:hover {
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .comm-blog-h2 {
      font-size: 32px;
    }
  }
</style>
