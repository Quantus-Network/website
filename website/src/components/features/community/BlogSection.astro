---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="comm-blog">
  <div class="comm-divider"></div>
  <div class="comm-section-inner">
    <span class="comm-eyebrow comm-animate" data-delay="0">
      {t("v2.community.blog.eyebrow")}
    </span>
    <h2 class="comm-blog-h2 comm-animate" data-delay="0.1">
      {t("v2.community.blog.heading")}
    </h2>
    <p class="comm-blog-sub comm-animate" data-delay="0.2">
      {t("v2.community.blog.sub")}
    </p>

    <a
      href="blog/weekly-update-03-24-2026.html"
      class="comm-blog-row comm-animate"
      data-delay="0"
    >
      <div class="comm-blog-row-left">
        <div class="comm-blog-row-top">
          <span class="comm-blog-date">
            {t("v2.community.blog.posts.post1.date")}
          </span>
          <span class="comm-blog-tag">
            {t("v2.community.blog.posts.post1.tag")}
          </span>
        </div>
        <span class="comm-blog-title">
          {t("v2.community.blog.posts.post1.title")}
        </span>
      </div>
      <span class="comm-blog-arrow">→</span>
    </a>

    <a
      href="blog/weekly-update-03-16-2026.html"
      class="comm-blog-row comm-animate"
      data-delay="0.1"
    >
      <div class="comm-blog-row-left">
        <div class="comm-blog-row-top">
          <span class="comm-blog-date">
            {t("v2.community.blog.posts.post2.date")}
          </span>
          <span class="comm-blog-tag">
            {t("v2.community.blog.posts.post2.tag")}
          </span>
        </div>
        <span class="comm-blog-title">
          {t("v2.community.blog.posts.post2.title")}
        </span>
      </div>
      <span class="comm-blog-arrow">→</span>
    </a>

    <a
      href="blog/weekly-update-03-07-2026.html"
      class="comm-blog-row comm-animate"
      data-delay="0.2"
    >
      <div class="comm-blog-row-left">
        <div class="comm-blog-row-top">
          <span class="comm-blog-date">
            {t("v2.community.blog.posts.post3.date")}
          </span>
          <span class="comm-blog-tag">
            {t("v2.community.blog.posts.post3.tag")}
          </span>
        </div>
        <span class="comm-blog-title">
          {t("v2.community.blog.posts.post3.title")}
        </span>
      </div>
      <span class="comm-blog-arrow">→</span>
    </a>

    <a
      href="blog/index.html"
      class="comm-blog-view-all comm-animate"
      data-delay="0.3"
      >{t("v2.community.blog.view_all")}</a
    >
  </div>
</section>

<style>
  #comm-blog {
    background: #0e0e0e;
  }

  .comm-blog-h2 {
    font-family: "Geist", sans-serif;
    font-size: 48px;
    font-weight: 500;
    color: #ffffff;
    margin-top: 16px;
    margin-bottom: 0;
  }

  .comm-blog-sub {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    color: rgba(232, 230, 224, 0.6);
    margin-top: 16px;
    margin-bottom: 48px;
    max-width: 520px;
  }

  .comm-blog-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    border-bottom: 1px solid rgba(232, 230, 224, 0.08);
    text-decoration: none;
    cursor: pointer;
    transition: padding-left 0.2s ease;
  }
  .comm-blog-row:first-of-type {
    border-top: 1px solid rgba(232, 230, 224, 0.08);
  }
  .comm-blog-row:hover {
    padding-left: 8px;
  }

  .comm-blog-row-left {
    flex: 1;
  }

  .comm-blog-row-top {
    display: flex;
    align-items: center;
  }

  .comm-blog-date {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .comm-blog-tag {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    text-transform: uppercase;
    padding: 2px 10px;
    border: 1px solid rgba(232, 230, 224, 0.12);
    color: rgba(232, 230, 224, 0.45);
    margin-left: 12px;
  }

  .comm-blog-title {
    font-family: "Geist", sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: rgba(232, 230, 224, 0.9);
    margin-top: 8px;
    display: block;
  }

  .comm-blog-arrow {
    font-size: 18px;
    color: #ff6b35;
    flex-shrink: 0;
    margin-left: 24px;
  }

  .comm-blog-view-all {
    display: block;
    margin-top: 32px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: #ff6b35;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .comm-blog-view-all:hover {
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .comm-blog-h2 {
      font-size: 32px;
    }
  }
</style>
