---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="podcast">
  <div class="comm-divider"></div>
  <div class="comm-section-inner">
    <div class="podcast-grid">
      <div class="comm-animate" data-delay="0">
        <span class="comm-eyebrow">{t("community.podcast.eyebrow")}</span>
        <h2 class="podcast-h2">{t("community.podcast.heading")}</h2>
        <p class="podcast-body">
          {t("community.podcast.body")}
        </p>
        <div class="podcast-cta-stack">
          <a
            href="https://open.spotify.com/show/1cWgZhnmRxpBO9QmbZ8wLM?si=6kLE7qfsQi6D56-LO4LCAA"
            target="_blank"
            rel="noopener"
            class="podcast-cta-link">{t("community.podcast.cta_spotify")}</a
          >
          <a
            href="https://podcasts.apple.com/us/podcast/quantus-podcast/id1850216581"
            target="_blank"
            rel="noopener"
            class="podcast-cta-link">{t("community.podcast.cta_apple")}</a
          >
        </div>
      </div>
      <div class="comm-animate" data-delay="0.15">
        <div class="pod-thumb">
          <a
            href="https://www.youtube.com/watch?v=wz6d0qRRHLs"
            target="_blank"
            rel="noopener"
          >
            <img
              src="https://img.youtube.com/vi/wz6d0qRRHLs/maxresdefault.jpg"
              alt="QDay Podcast Episode 18"
            />
            <div class="pod-play-overlay">
              <div class="pod-play-circle">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path
                    d="M6 4L16 10L6 16V4Z"
                    fill="white"
                    transform="translate(1,0)"></path>
                </svg>
              </div>
            </div>
          </a>
        </div>
        <span class="pod-episode-title">
          {t("community.podcast.episode.title")}
        </span>
        <span class="pod-episode-meta">
          {t("community.podcast.episode.meta")}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  #podcast {
    background: #0e0e0e;
  }

  .podcast-grid {
    display: grid;
    grid-template-columns: 50% 50%;
    gap: 60px;
    align-items: start;
  }

  .podcast-h2 {
    font-family: "Geist", sans-serif;
    font-size: 42px;
    font-weight: 500;
    color: #ffffff;
    line-height: 1.1;
    margin-top: 16px;
    margin-bottom: 0;
  }

  .podcast-body {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    color: rgba(232, 230, 224, 0.65);
    line-height: 1.7;
    margin-top: 20px;
    max-width: 400px;
  }

  .podcast-cta-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }

  .podcast-cta-link {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: #ff6b35;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .podcast-cta-link:hover {
    opacity: 0.75;
  }

  .pod-thumb {
    width: 100%;
    max-width: 480px;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(232, 230, 224, 0.08);
    display: block;
  }

  .pod-thumb a {
    display: block;
    position: relative;
  }

  .pod-thumb a img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .pod-thumb a:hover img {
    opacity: 0.85;
  }

  .pod-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .pod-play-circle {
    width: 56px;
    height: 56px;
    background: rgba(255, 107, 53, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pod-episode-title {
    font-family: "Geist", sans-serif;
    font-size: 15px;
    color: rgba(232, 230, 224, 0.8);
    line-height: 1.4;
    margin-top: 16px;
    display: block;
  }

  .pod-episode-meta {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: rgba(232, 230, 224, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin-top: 6px;
  }

  @media (max-width: 768px) {
    .podcast-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
