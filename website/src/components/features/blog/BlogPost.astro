---
import Layout from "@/components/layout/Layout.astro";
import Card from "@/components/features/blog/Card.astro";
import type { CollectionEntry } from "astro:content";
import type { Article, WithContext } from "schema-dts";
import {
  getLocaleFromUrl,
  getLocalizedPath,
  createTranslator,
} from "@/utils/i18n";
import env from "@/config";
import { createMetadata } from "@/utils/create-metadata";

type Props = CollectionEntry<"blog">["data"] & {
  relatedPosts?: CollectionEntry<"blog">[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  tags = [],
  relatedPosts = [],
} = Astro.props;

const currentLocale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(currentLocale);

const metadata = createMetadata({
  title,
  description,
  pathname: Astro.url.pathname,
  imageUrl: heroImage,
  imageAlt: heroAlt,
});

const blogIndexHref = getLocalizedPath(currentLocale, "/blog");

const articleSchema: WithContext<Article> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  url: metadata.canonical as string,
  image: metadata.openGraph?.basic?.image,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate?.toISOString() || pubDate.toISOString(),
  author: {
    "@type": "Organization",
    name: env.SITE_NAME,
    url: env.SITE_BASE_URL,
  },
};
---

<Layout {...metadata} jsonLd={articleSchema}>
  <article class="blog-post">
    <section class="bg-void">
      <div
        class="px-content-edges max-md:px-content-edges-mobile max-w-[860px] pt-[140px] pb-16 max-md:pt-[120px] max-md:pb-12"
      >
        <a
          href={blogIndexHref}
          class="blog-post-back text-content-40 hover:text-flare mb-8 inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.16em] uppercase no-underline transition-colors"
        >
          {t("blog.post.back_to_blog")}
        </a>

        {
          tags.length > 0 && (
            <div class="mb-5 flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <span class="blog-post-tag-pill">
                  <a
                    href={getLocalizedPath(currentLocale, `/blog/tags/${tag}`)}
                    class="hover:text-flare text-inherit no-underline transition-colors"
                  >
                    {t(`blog.tags.${tag}`) || tag}
                  </a>
                </span>
              ))}
            </div>
          )
        }

        <h1
          class="font-primary mb-6 text-[clamp(28px,3.5vw,52px)] leading-[1.18] font-medium text-white"
        >
          {title}
        </h1>

        <p
          class="text-content-35 font-mono text-xs tracking-[0.12em] uppercase"
        >
          <time datetime={pubDate.toISOString()}>
            {
              pubDate.toLocaleDateString(currentLocale, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          <span class="text-content-35">&nbsp;·&nbsp;</span>
          <span>{t("blog.post.author")}</span>
        </p>
        {
          updatedDate && (
            <p class="text-content-40 mt-3 font-mono text-[11px] tracking-[0.08em] normal-case not-italic">
              {updatedDate.toLocaleDateString(currentLocale, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
          )
        }
      </div>
    </section>

    {
      heroImage && (
        <>
          <div class="max-h-[480px] w-full overflow-hidden">
            <img
              width={1020}
              height={510}
              src={heroImage}
              alt={heroAlt || title}
              class="block h-full max-h-[480px] w-full object-cover"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
          <div class="bg-flare h-px w-full" aria-hidden="true" />
        </>
      )
    }

    <div
      class="px-content-edges max-md:px-content-edges-mobile max-w-[860px] pt-16 pb-16 max-md:pt-12 max-md:pb-20"
    >
      <div class="blog-post-prose prose prose-invert max-w-none">
        <slot />
      </div>

      {
        relatedPosts.length > 0 && (
          <div class="border-content-8 mt-10 max-w-[860px] border-t pt-10 pb-24">
            <h2 class="font-primary mb-8 text-2xl font-medium text-white">
              {t("blog.related_posts")}
            </h2>
            <div class="flex flex-col gap-3">
              {relatedPosts.map((relatedPost) => (
                <Card
                  title={relatedPost.data.title}
                  description={relatedPost.data.description}
                  pubDate={relatedPost.data.pubDate}
                  href={getLocalizedPath(
                    currentLocale,
                    `/blog/${relatedPost.id.split("/").slice(1).join("/")}`,
                  )}
                  tags={relatedPost.data.tags}
                  heroImage={relatedPost.data.heroImage}
                  heroAlt={relatedPost.data.heroAlt}
                  featured={relatedPost.data.featured}
                  horizontal={true}
                />
              ))}
            </div>
          </div>
        )
      }
    </div>
  </article>
</Layout>

<style is:global>
  .blog-post-tag-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-content-45);
    border: 1px solid var(--color-content-12);
    padding: 4px 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .blog-post-back::before,
  .blog-post-back-footer::before {
    content: "←";
    margin-right: 4px;
  }

  .blog-post-prose.prose :where(p):not(:where([class~="not-prose"] *)) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-content-70);
    margin-bottom: 24px;
  }

  .blog-post-prose.prose :where(h2):not(:where([class~="not-prose"] *)),
  .blog-post-prose.prose :where(h3):not(:where([class~="not-prose"] *)) {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-flare);
    margin-top: 48px;
    margin-bottom: 16px;
    line-height: 1.4;
  }

  .blog-post-prose.prose
    :where(h2):not(:where([class~="not-prose"] *)):first-child,
  .blog-post-prose.prose
    :where(h3):not(:where([class~="not-prose"] *)):first-child {
    margin-top: 0;
  }

  .blog-post-prose.prose :where(h1):not(:where([class~="not-prose"] *)) {
    color: var(--color-white);
    font-weight: 600;
  }

  .blog-post-prose.prose :where(h4):not(:where([class~="not-prose"] *)) {
    color: var(--color-white);
    font-weight: 600;
  }

  .blog-post-prose.prose :where(ul, ol):not(:where([class~="not-prose"] *)) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-content-70);
    padding-left: 20px;
    margin-bottom: 24px;
  }

  .blog-post-prose.prose :where(li):not(:where([class~="not-prose"] *)) {
    margin-bottom: 8px;
  }

  .blog-post-prose.prose :where(a):not(:where([class~="not-prose"] *)) {
    color: var(--color-flare);
    text-decoration: none;
    border-bottom: 1px solid var(--color-flare-30);
    transition: border-color 0.2s ease;
  }

  .blog-post-prose.prose :where(a):not(:where([class~="not-prose"] *)):hover {
    border-color: var(--color-flare);
  }

  .blog-post-prose.prose
    :where(blockquote):not(:where([class~="not-prose"] *)) {
    border-left: 4px solid var(--color-flare);
    padding-left: 1em;
    font-style: italic;
    margin-bottom: 1.25em;
    color: var(--color-content-70);
  }

  .blog-post-prose.prose
    :where(code):not(:where([class~="not-prose"] *)):not(pre code) {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-content);
  }

  .blog-post-prose.prose :where(pre):not(:where([class~="not-prose"] *)) {
    background-color: #1a1a1a;
    border-radius: 0;
    margin-bottom: 1.25em;
  }

  .blog-post-prose.prose :where(img):not(:where([class~="not-prose"] *)) {
    border-radius: 0;
  }

  .blog-post-prose.prose :where(strong):not(:where([class~="not-prose"] *)) {
    font-weight: 600;
    color: var(--color-content-85);
  }

  .blog-post-prose.prose :where(table):not(:where([class~="not-prose"] *)) {
    font-size: 16px;
    color: var(--color-content-70);
  }

  .blog-post-prose.prose :where(th, td):not(:where([class~="not-prose"] *)) {
    border: 1px solid var(--color-content-12);
  }

  .blog-post-prose.prose :where(th):not(:where([class~="not-prose"] *)) {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-content-85);
    background: rgba(255, 255, 255, 0.04);
  }
</style>
