---
import {
  getLocaleFromUrl,
  getLocalizedPath,
  createTranslator,
} from "@/utils/i18n";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  tags?: string[];
  heroImage?: string;
  heroAlt?: string;
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  href,
  tags = [],
  heroImage,
  heroAlt,
  featured,
} = Astro.props;

const currentLocale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(currentLocale);

const formattedDate = pubDate
  .toLocaleDateString(currentLocale, {
    year: "numeric",
    month: "short",
    day: "numeric",
  })
  .toUpperCase();
---

<a
  href={href}
  class="group flex flex-col border border-border text-inherit no-underline transition-colors duration-200 hover:border-content-15 hover:bg-surface"
>
  {
    heroImage && (
      <div class="relative aspect-video w-full overflow-hidden">
        <img
          src={heroImage}
          alt={heroAlt || title}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
          fetchpriority="low"
        />
        <div class="absolute inset-0 flex items-center justify-center bg-void/55 opacity-0 backdrop-blur-xs transition-opacity duration-250 group-hover:opacity-100">
          <span class="font-mono text-[13px] font-medium tracking-[0.2em] text-flare">
            READ
          </span>
        </div>
      </div>
    )
  }
  <div class="flex flex-1 flex-col px-5 pb-7 pt-6">
    <time
      datetime={pubDate.toISOString()}
      class="font-mono mb-2.5 block text-[11px] tracking-[0.14em] text-content-35 uppercase"
    >
      {formattedDate}
    </time>
    <span class="block text-[17px] font-medium leading-[1.35] text-content-90">
      {title}
    </span>
    {
      tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-1.5 pt-4">
          {tags.slice(0, 4).map((tag) => (
            <span class="font-mono text-[10px] tracking-widest text-content-40 border border-content-10 px-2.5 py-0.5 uppercase">
              {t(`blog.tags.${tag}`) || tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
