---
import SectionWrapper from "./SectionWrapper.astro";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<SectionWrapper
  id="architecture"
  title={t("v2.technology.architecture.title")}
  subtitle={t("v2.technology.architecture.subtitle")}
  content={t("v2.technology.architecture.content")}
>
  <div class="tech-cols-3">
    <div class="tech-col-card">
      <span class="tech-col-title">
        {t("v2.technology.architecture.cards.signatures.title")}
      </span>
      <p class="tech-col-body">
        {t("v2.technology.architecture.cards.signatures.body")}
      </p>
    </div>
    <div class="tech-col-card">
      <span class="tech-col-title">
        {t("v2.technology.architecture.cards.network_layer.title")}
      </span>
      <p class="tech-col-body">
        {t("v2.technology.architecture.cards.network_layer.body")}
      </p>
    </div>
    <div class="tech-col-card">
      <span class="tech-col-title">
        {t("v2.technology.architecture.cards.scale.title")}
      </span>
      <p class="tech-col-body">
        {t("v2.technology.architecture.cards.scale.body")}
      </p>
    </div>
  </div>
</SectionWrapper>

<style>
  .tech-cols-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid rgba(232, 230, 224, 0.08);
  }

  .tech-col-card {
    padding: 36px 32px;
    border-right: 1px solid rgba(232, 230, 224, 0.08);
    transition: background 0.3s ease;
  }
  .tech-col-card:last-child {
    border-right: none;
  }
  .tech-col-card:hover {
    background: rgba(232, 230, 224, 0.03);
  }

  .tech-col-title {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ff6b35;
    display: block;
    margin-bottom: 20px;
  }

  .tech-col-body {
    font-family: "Geist", sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: rgba(232, 230, 224, 0.6);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .tech-cols-3 {
      grid-template-columns: 1fr;
    }
    .tech-col-card {
      border-right: none;
      border-bottom: 1px solid rgba(232, 230, 224, 0.08);
    }
    .tech-col-card:last-child {
      border-bottom: none;
    }
  }
</style>
