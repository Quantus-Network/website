---
import SectionWrapper from "./SectionWrapper.astro";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<SectionWrapper
  id="consensus"
  title={t("v2.technology.consensus.title")}
  subtitle={t("v2.technology.consensus.subtitle")}
>
  <div class="tech-consensus-block">
    <p class="tech-consensus-body">
      {t("v2.technology.consensus.body")}
    </p>
  </div>
</SectionWrapper>

<style>
  .tech-consensus-block {
    border: 1px solid rgba(232, 230, 224, 0.08);
    padding: 52px;
  }

  .tech-consensus-body {
    font-family: "Geist", sans-serif;
    font-size: 17px;
    color: rgba(232, 230, 224, 0.55);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .tech-consensus-block {
      padding: 32px 24px;
    }
  }
</style>
