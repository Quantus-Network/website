        stroke="rgba(255,107,53,0.1)"
        stroke-width="0.5"></line>
      <line
        x1="370"
        y1="323"
        x2="250"
        y2="390"
        stroke="rgba(255,107,53,0.1)"
        stroke-width="0.5"></line>
      <line
        x1="250"
        y1="390"
        x2="130"
        y2="323"
        stroke="rgba(255,107,53,0.1)"
        stroke-width="0.5"></line>
      <line
        x1="130"
        y1="323"
        x2="130"
        y2="177"
        stroke="rgba(255,107,53,0.1)"
        stroke-width="0.5"></line>
      <line
        x1="130"
        y1="177"
        x2="250"
        y2="110"
        stroke="rgba(255,107,53,0.1)"
        stroke-width="0.5"></line>
      <!-- Outer vertex dots -->
      <circle cx="250" cy="40" r="3" fill="rgba(232,230,224,0.5)"></circle>
      <circle cx="420" cy="145" r="3" fill="rgba(232,230,224,0.5)"></circle>
      <circle cx="420" cy="355" r="3" fill="rgba(232,230,224,0.5)"></circle>
      <circle cx="250" cy="460" r="3" fill="rgba(232,230,224,0.5)"></circle>
      <circle cx="80" cy="355" r="3" fill="rgba(232,230,224,0.5)"></circle>
