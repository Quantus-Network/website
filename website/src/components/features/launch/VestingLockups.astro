---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
---

<div class="vest-wrap my-8">
  <!-- Mobile: milestone legend -->
  <div class="mb-2 flex items-center md:hidden">
    <div class="text-quantus-white/30 flex w-full justify-between text-[9px]">
      <span class="w-[20%] text-center">{t("launch.vesting.mark_tge")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y1")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y2")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y3")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y4")}</span>
    </div>
  </div>

  <div class="mb-2 hidden md:flex md:items-center md:gap-3">
    <div class="w-[150px] shrink-0" aria-hidden="true"></div>
    <div class="text-quantus-white/30 flex flex-1 justify-between text-[10px]">
      <span class="w-[20%] text-center">{t("launch.vesting.mark_tge")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y1")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y2")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y3")}</span>
      <span class="w-[20%] text-center">{t("launch.vesting.mark_y4")}</span>
    </div>
  </div>

  <!-- Investors -->
  <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
    <div
      class="text-quantus-white/70 w-full shrink-0 text-left text-sm md:w-[150px] md:text-right"
    >
      {t("launch.vesting.row_investors")}
    </div>
    <div
      class="bg-quantus-white/5 relative h-[30px] w-full overflow-hidden rounded md:flex-1"
    >
      <div
        class="absolute top-0 left-0 flex h-full w-full items-center justify-center bg-linear-to-r from-[rgba(34,197,94,0.35)] to-[rgba(34,197,94,0.08)]"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-[#22a85a] uppercase"
          >{t("launch.vesting.investors_bar")}</span
        >
      </div>
    </div>
  </div>

  <!-- DEX Liquidity -->
  <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
    <div
      class="text-quantus-white/70 w-full shrink-0 text-left text-sm md:w-[150px] md:text-right"
    >
      {t("launch.vesting.row_dex")}
    </div>
    <div
      class="bg-quantus-white/5 relative h-[30px] w-full overflow-hidden rounded md:flex-1"
    >
      <div
        class="absolute top-0 left-0 flex h-full w-full items-center justify-center bg-linear-to-r from-[rgba(34,197,94,0.35)] to-[rgba(34,197,94,0.08)]"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-[#22a85a] uppercase"
          >{t("launch.vesting.dex_bar")}</span
        >
      </div>
    </div>
  </div>

  <!-- Team & Founders -->
  <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
    <div
      class="text-quantus-white/70 w-full shrink-0 text-left text-sm md:w-[150px] md:text-right"
    >
      {t("launch.vesting.row_team")}
    </div>
    <div
      class="bg-quantus-white/5 relative h-[30px] w-full overflow-hidden rounded md:flex-1"
    >
      <div
        class="absolute top-0 left-0 flex h-[30px] w-[30%] items-center justify-center border-r-2 border-[#8b5cf6]"
        style="background: repeating-linear-gradient(-45deg, rgba(139,92,246,0.25), rgba(139,92,246,0.25) 4px, transparent 4px, transparent 8px);"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-white uppercase"
          >{t("launch.vesting.cliff")}</span
        >
      </div>
      <div
        class="absolute top-0 left-[30%] flex h-[30px] w-[60%] items-center justify-center bg-linear-to-r from-[rgba(139,92,246,0.4)] to-[rgba(139,92,246,0.1)]"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-white uppercase"
          >{t("launch.vesting.linear_monthly")}</span
        >
      </div>
    </div>
  </div>

  <!-- Advisors -->
  <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
    <div
      class="text-quantus-white/70 w-full shrink-0 text-left text-sm md:w-[150px] md:text-right"
    >
      {t("launch.vesting.row_advisors")}
    </div>
    <div
      class="bg-quantus-white/5 relative h-[30px] w-full overflow-hidden rounded md:flex-1"
    >
      <div
        class="absolute top-0 left-0 flex h-[30px] w-[30%] items-center justify-center border-r-2 border-[#8b5cf6]"
        style="background: repeating-linear-gradient(-45deg, rgba(139,92,246,0.25), rgba(139,92,246,0.25) 4px, transparent 4px, transparent 8px);"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-white uppercase"
          >{t("launch.vesting.cliff")}</span
        >
      </div>
      <div
        class="absolute top-0 left-[30%] flex h-[30px] w-[60%] items-center justify-center bg-linear-to-r from-[rgba(139,92,246,0.4)] to-[rgba(139,92,246,0.1)]"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-white uppercase"
          >{t("launch.vesting.linear_monthly")}</span
        >
      </div>
    </div>
  </div>

  <!-- Company (Dev Tax) -->
  <div class="mb-2 flex flex-col gap-2 md:flex-row md:items-center md:gap-3">
    <div
      class="text-quantus-white/70 w-full shrink-0 text-left text-sm md:w-[150px] md:text-right"
    >
      {t("launch.vesting.row_company")}
    </div>
    <div
      class="bg-quantus-white/5 relative h-[30px] w-full overflow-hidden rounded md:flex-1"
    >
      <div
        class="absolute top-0 left-0 flex h-full w-full items-center justify-center bg-linear-to-r from-[rgba(43,188,179,0.35)] to-[rgba(43,188,179,0.05)]"
      >
        <span
          class="text-[10px] font-semibold tracking-wider text-[#2bbcb3] uppercase"
          >{t("launch.vesting.company_bar")}</span
        >
      </div>
    </div>
  </div>
</div>
