---
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="community">
  <div class="community-divider"></div>

  <div class="community-header">
    <span class="community-eyebrow">
      {t("home.community.eyebrow")}
    </span>
    <h2 class="community-headline">
      {t("home.community.headline")}
    </h2>
  </div>

  <!-- 2x2 Grid -->
  <div class="community-grid">
    <!-- TELEGRAM -->
    <div class="community-panel">
      <div>
        <div class="community-panel-top">
          <div class="community-panel-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.93 6.79l-1.69 7.96c-.12.55-.46.68-.93.43l-2.57-1.89-1.24 1.19c-.14.14-.26.26-.52.26l.18-2.6 4.73-4.27c.21-.18-.05-.28-.32-.1L8.17 14.17 5.63 13.4c-.55-.17-.56-.55.12-.81l9.64-3.72c.46-.17.86.11.54.92z"
                fill="rgba(232,230,224,0.4)"></path>
            </svg>
          </div>
          <span class="community-platform-label">
            {t("home.community.cards.telegram.label")}
          </span>
        </div>
        <p class="community-panel-desc">
          {t("home.community.cards.telegram.description")}
        </p>
      </div>
      <div>
        <a
          href="https://t.me/quantusnetwork"
          target="_blank"
          class="community-panel-cta"
        >
          {t("home.community.cards.telegram.cta")}
        </a>
      </div>
    </div>

    <!-- X -->
    <div class="community-panel">
      <div>
        <div class="community-panel-top">
          <div class="community-panel-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.733-8.835L2.25 2.25h6.844l4.262 5.632 4.888-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
                fill="rgba(232,230,224,0.4)"></path>
            </svg>
          </div>
          <span class="community-platform-label">
            {t("home.community.cards.x.label")}
          </span>
        </div>
        <p class="community-panel-desc">
          {t("home.community.cards.x.description")}
        </p>
      </div>
      <div>
        <a
          href="https://x.com/QuantusNetwork"
          target="_blank"
          class="community-panel-cta"
        >
          {t("home.community.cards.x.cta")}
        </a>
      </div>
    </div>

    <!-- INSTAGRAM -->
    <div class="community-panel">
      <div>
        <div class="community-panel-top">
          <div class="community-panel-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <rect
                x="2"
                y="2"
                width="20"
                height="20"
                rx="5"
                stroke="rgba(232,230,224,0.4)"
                stroke-width="1.5"
                fill="none"></rect>
              <circle
                cx="12"
                cy="12"
                r="4"
                stroke="rgba(232,230,224,0.4)"
                stroke-width="1.5"
                fill="none"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="rgba(232,230,224,0.4)"
              ></circle>
            </svg>
          </div>
          <span class="community-platform-label">
            {t("home.community.cards.instagram.label")}
          </span>
        </div>
        <p class="community-panel-desc">
          {t("home.community.cards.instagram.description")}
        </p>
      </div>
      <div>
        <a
          href="https://www.instagram.com/quantusnetwork/"
          target="_blank"
          class="community-panel-cta"
        >
          {t("home.community.cards.instagram.cta")}
        </a>
      </div>
    </div>

    <!-- YOUTUBE -->
    <div class="community-panel">
      <div>
        <div class="community-panel-top">
          <div class="community-panel-icon">
            <svg width="22" height="16" viewBox="0 0 24 17" fill="none">
              <path
                d="M23.495 2.659a3.01 3.01 0 00-2.117-2.133C19.476 0 12 0 12 0S4.524 0 2.622.526A3.01 3.01 0 00.505 2.659C0 4.576 0 8.571 0 8.571s0 3.996.505 5.913a3.01 3.01 0 002.117 2.133C4.524 17.143 12 17.143 12 17.143s7.476 0 9.378-.526a3.01 3.01 0 002.117-2.133C24 12.567 24 8.571 24 8.571s0-3.995-.505-5.912zM9.545 12.143V5l6.364 3.571-6.364 3.572z"
                fill="rgba(232,230,224,0.4)"></path>
            </svg>
          </div>
          <span class="community-platform-label">
            {t("home.community.cards.youtube.label")}
          </span>
        </div>
        <p class="community-panel-desc">
          {t("home.community.cards.youtube.description")}
        </p>
      </div>
      <div>
        <a
          href="https://www.youtube.com/@QuantusNetwork"
          target="_blank"
          class="community-panel-cta"
        >
          {t("home.community.cards.youtube.cta")}
        </a>
      </div>
    </div>
  </div><!-- /.community-grid -->
</section>

<style>
  #community {
    background: #0e0e0e;
    position: relative;
    z-index: 50;
    padding: 0 0 80px 0;
  }
  .community-divider {
    position: relative;
    width: 0;
    height: 1px;
    background: #ff6b35;
    transition: width 0.8s ease-out;
    margin: 0;
    padding: 0;
    display: block;
    left: 0;
  }
  .community-divider.expanded {
    width: 100vw;
  }
  .community-header {
    padding: 80px 52px 0;
    text-align: left;
  }
  .community-eyebrow {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232, 230, 224, 0.35);
    display: block;
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s ease 0s,
      transform 0.7s ease 0s;
  }
  .community-eyebrow.in {
    opacity: 1;
    transform: none;
  }
  .community-headline {
    font-family: "Geist", sans-serif;
    font-size: 52px;
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin-bottom: 56px;
    text-align: left;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s ease 0.15s,
      transform 0.7s ease 0.15s;
  }
  .community-headline.in {
    opacity: 1;
    transform: none;
  }
  /* Grid — border-collapse trick: parent has top+left, each cell has right+bottom */
  .community-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin: 48px 52px 0;
    border-top: 1px solid rgba(232, 230, 224, 0.08);
    border-left: 1px solid rgba(232, 230, 224, 0.08);
  }
  .community-panel {
    border-right: 1px solid rgba(232, 230, 224, 0.08);
    border-bottom: 1px solid rgba(232, 230, 224, 0.08);
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
    transition: background 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
  }
  .community-panel:hover {
    background: rgba(232, 230, 224, 0.04);
  }
  .community-panel.in {
    opacity: 1;
    transform: none;
  }
  .community-panel-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .community-panel-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .community-panel-icon svg {
    display: block;
  }
  .community-platform-label {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(232, 230, 224, 0.4);
  }
  .community-panel-desc {
    font-family: "Geist", sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: rgba(232, 230, 224, 0.45);
    margin-bottom: 24px;
  }
  .community-panel-cta {
    border: 1px solid rgba(232, 230, 224, 0.15);
    padding: 8px 16px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(232, 230, 224, 0.5);
    display: inline-block;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .community-panel-cta:hover {
    border-color: #ff6b35;
    color: #ff6b35;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  @media (max-width: 768px) {
    /* ── COMMUNITY SECTION ── */
    #community .community-header {
      padding: 60px 24px 0 !important;
    }

    #community .community-headline {
      font-size: 32px !important;
      margin-bottom: 24px !important;
    }

    #community .community-grid {
      margin: 24px 16px 0 !important;
    }

    #community .community-panel {
      padding: 20px 16px !important;
      min-height: 140px !important;
    }

    .community-panel-cta {
      font-size: 10px;
      padding: 6px 10px;
      white-space: nowrap;
      display: inline-block;
    }
  }
</style>

<script>
  const section = document.getElementById("community")!;
  const divider = section.querySelector(".community-divider")!;
  const eyebrow = section.querySelector(".community-eyebrow")!;
  const headline = section.querySelector(".community-headline")!;
  const panels = section.querySelectorAll(
    ".community-panel",
  ) as NodeListOf<HTMLElement>;
  const delays = [0.3, 0.45, 0.6, 0.75];

  let animated = false;
  const obs = new IntersectionObserver(
    (entries) => {
      if (entries[0].intersectionRatio >= 0.15 && !animated) {
        animated = true;
        obs.disconnect();
        divider.classList.add("expanded");
        eyebrow.classList.add("in");
        headline.classList.add("in");
        panels.forEach((panel, i) => {
          panel.style.transition = `opacity 0.7s ease ${delays[i]}s, transform 0.7s ease ${delays[i]}s`;
          panel.classList.add("in");
        });
      }
    },
    { threshold: 0.15 },
  );
  obs.observe(section);
</script>
