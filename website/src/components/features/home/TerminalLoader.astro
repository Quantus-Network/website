<div id="loader">
  <div id="terminal"></div>
  <div id="ascii-stage"><div id="ascii-out"></div></div>
</div>

<style is:global>
  .tl {
    opacity: 0;
  }

  .tl.on {
    opacity: 1;
  }

  .tl .ac {
    color: var(--color-flare);
  }

  .tl .ok {
    color: #4ade80;
  }

  .blink {
    display: inline-block;
    width: 6px;
    height: 11px;
    background: var(--color-flare);
    vertical-align: middle;
    animation: bl 0.9s step-end infinite;
  }
</style>

<style>
  #loader {
    position: fixed;
    inset: 0;
    background: var(--color-void);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: opacity 0.5s ease;
  }
  #loader.out {
    opacity: 0;
    pointer-events: none;
  }

  #terminal {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    color: rgba(232, 230, 224, 0.35);
    line-height: 1.9;
    padding: 44px 52px 0;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  #ascii-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 48px 36px;
  }
  #ascii-out {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    line-height: 1.18;
    letter-spacing: 0.06em;
    white-space: pre;
    color: rgba(255, 107, 53, 0);
    transition: color 0.35s;
  }
  #ascii-out.lit {
    color: rgba(255, 107, 53, 0.5);
  }
</style>

<script>
  import { updateHeroActive } from "@/scripts/home/hero";
  import { initLoader } from "@/scripts/home/loader";

  if (!sessionStorage.getItem("quantus_loaded")) {
    sessionStorage.setItem("quantus_loaded", "1");
    setTimeout(initLoader, 100);
  } else {
    const loader = document.getElementById("loader");
    if (loader) {
      loader.style.display = "none";
    }
    const hero = document.getElementById("hero");
    if (hero) {
      hero.style.opacity = "1";
      hero.classList.add("on");
    }
    const hc = document.getElementById("hc");
    if (hc) setTimeout(() => hc.classList.add("in"), 100);

    updateHeroActive(true);
  }
</script>
