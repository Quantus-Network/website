---
import type { Locale } from "@/utils/i18n";
import { formatDate } from "@/utils/i18n";
import VersionSelector from "./VersionSelector.astro";
import DownloadButton from "./DownloadButton.astro";

export interface Props {
  title: string;
  version: string;
  latestVersion: string;
  versions: { version: string; date: Date }[];
  updatedDate?: Date;
  publishedDate: Date;
  authors: string[];
  pdfHref: string;
  locale: Locale;
  t: (key: string) => string;
  /** When set with pdf cover, hide header in print so the cover replaces it. */
  class?: string;
}

const {
  title,
  version,
  latestVersion,
  versions,
  updatedDate,
  publishedDate,
  authors,
  pdfHref,
  locale,
  t,
  class: className = "",
} = Astro.props;

const displayDate = updatedDate ?? publishedDate;
---

<header
  class:list={[
    "mb-10 border-b border-white/10 pb-10 print:border-black/10",
    className,
  ]}
  id="top"
>
  <div class="flex flex-col gap-4">
    <div>
      <h1
        class="font-small-title lg:font-medium-title mb-3 text-white print:text-black"
      >
        {title}
      </h1>
      <div
        class="flex flex-wrap items-center gap-3 text-sm text-white/50 print:text-[#666]"
      >
        <p>
          <span class="font-bold">{t("whitepaper.authors")}:</span>
          {authors.join(", ")}
        </p>
        <span class="text-white/20 print:text-[#ccc]">|</span>
        <p>
          <span class="font-bold">
            {t("whitepaper.last_updated")}:
          </span>

          {
            formatDate(displayDate, locale, {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>
      </div>
    </div>

    <div class="flex items-center gap-3 print:hidden">
      {
        versions.length >= 1 && (
          <VersionSelector
            versions={versions}
            currentVersion={version}
            locale={locale}
            latestVersion={latestVersion}
            t={t}
          />
        )
      }
      <DownloadButton href={pdfHref} label={t("whitepaper.download_pdf")} />
    </div>
  </div>
</header>
