---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  number?: number;
  width?: string;
}

const { src, alt, caption, number, width } = Astro.props;
---

<figure class="not-prose my-8">
  <div class="overflow-hidden rounded-lg border border-white/10">
    <img
      src={src}
      alt={alt}
      class="w-full"
      style={width ? `max-width: ${width}; margin: 0 auto; display: block;` : undefined}
      loading="lazy"
      decoding="async"
    />
  </div>
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-white/50">
      {number != null && <span class="font-semibold text-white/70">Figure {number}. </span>}
      {caption}
    </figcaption>
  )}
</figure>
