---
export interface Props {
  ratio?: number | string;
  class?: string;
}

const { ratio = 1, class: className } = Astro.props;
---

<div
  class:list={["column min-w-0 [&>*:first-child]:mt-0", className]}
  style={{ "--ratio": ratio }}
>
  <slot />
</div>

<style>
  .column {
    flex: 1 1 100%;
  }

  @media (min-width: 768px) {
    .column {
      flex: var(--ratio) 1 0%;
    }
  }

  @media print {
    .column {
      flex: var(--ratio) 1 0% !important;
    }
  }
</style>
