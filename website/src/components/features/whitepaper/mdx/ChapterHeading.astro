---
import Divider from "./Divider.astro";

export interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<Divider />

<h2 id={`chapter-${number}`} class="not-prose flex flex-col">
  <br />
  <br />

  <span
    class="font-whitepaper-chapter-number text-whitepaper-primary translate-y-[14px] opacity-15"
    >{number}</span
  >

  <span class="font-whitepaper-chapter-title">{title}</span>
</h2>
