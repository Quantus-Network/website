---
import Divider from "./Divider.astro";

export interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<div id={`chapter-${number}`} class="not-prose flex flex-col">
  <Divider />

  <br />
  <br />

  <span
    class="font-whitepaper-chapter-number text-whitepaper-primary translate-y-[14px] opacity-15"
    >{number}</span
  >

  <h2 class="font-whitepaper-chapter-title">
    <span>{title}</span>
  </h2>
</div>
