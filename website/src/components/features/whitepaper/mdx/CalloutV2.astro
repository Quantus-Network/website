---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<aside
  class:list={[
    "not-prose border-whitepaper-primary print:bg-whitepaper-callout-background my-6 border-l-2 bg-white/10 px-5 py-4",
  ]}
  role="note"
>
  <p class="font-whitepaper-callout-title text-whitepaper-primary mb-2">
    {title}
  </p>

  <div class="font-whitepaper-callout-body print:text-whitepaper-body-light">
    <slot />
  </div>
</aside>
