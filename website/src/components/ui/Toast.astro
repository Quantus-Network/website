---
export interface Props {
  id?: string;
}

const { id = "toast-container" } = Astro.props;
---

<div
  id={id}
  class="toast-stack pointer-events-none fixed right-4 bottom-4 flex max-w-[min(22rem,calc(100vw-2rem))] flex-col gap-2 sm:right-6 sm:bottom-6"
>
</div>

<script>
  type ToastType = "success" | "error" | "info";

  interface ToastOptions {
    type?: ToastType;
    duration?: number;
  }

  class ToastManager {
    private container: HTMLElement;
    private toasts: Map<string, HTMLElement> = new Map();

    constructor(containerId: string = "toast-container") {
      const container = document.getElementById(containerId);
      if (!container) {
        throw new Error(`Toast container with id "${containerId}" not found`);
      }
      this.container = container;
    }

    show(message: string, options: ToastOptions = {}) {
      const { type = "info", duration = 3000 } = options;
      const id = `toast-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;

      const toast = this.createToast(id, message, type);
      this.container.appendChild(toast);
      this.toasts.set(id, toast);

      requestAnimationFrame(() => {
        toast.classList.remove("toast--hidden");
      });

      setTimeout(() => {
        this.dismiss(id);
      }, duration);

      return id;
    }

    success(message: string, duration?: number) {
      return this.show(message, { type: "success", duration });
    }

    error(message: string, duration?: number) {
      return this.show(message, { type: "error", duration });
    }

    info(message: string, duration?: number) {
      return this.show(message, { type: "info", duration });
    }

    dismiss(id: string) {
      const toast = this.toasts.get(id);
      if (!toast) return;

      toast.classList.add("toast--hidden");

      setTimeout(() => {
        toast.remove();
        this.toasts.delete(id);
      }, 300);
    }

    private createToast(
      id: string,
      message: string,
      type: ToastType,
    ): HTMLElement {
      const toast = document.createElement("div");
      toast.id = id;
      toast.setAttribute("role", "alert");
      toast.className = `toast toast--${type} toast--hidden pointer-events-auto`;

      const icon = this.getIcon(type);
      const closeBtn = this.createCloseButton(id);

      toast.innerHTML = `
        <div class="toast__rail" aria-hidden="true"></div>
        <div class="toast__main">
          <div class="toast__icon">${icon}</div>
          <p class="toast__message">${this.escapeHtml(message)}</p>
        </div>
      `;
      toast.appendChild(closeBtn);

      return toast;
    }

    private createCloseButton(id: string): HTMLButtonElement {
      const btn = document.createElement("button");
      btn.className = "toast__close";
      btn.setAttribute("aria-label", "Close notification");
      btn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M12.8 4.27333L11.7267 3.2L8 6.92667L4.27333 3.2L3.2 4.27333L6.92667 8L3.2 11.7267L4.27333 12.8L8 9.07333L11.7267 12.8L12.8 11.7267L9.07333 8L12.8 4.27333Z" fill="currentColor"/>
        </svg>
      `;
      btn.addEventListener("click", () => this.dismiss(id));
      return btn;
    }

    private getIcon(type: ToastType): string {
      const icons = {
        success: `
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM8 15L3 10L4.41 8.59L8 12.17L15.59 4.58L17 6L8 15Z" fill="currentColor"/>
          </svg>
        `,
        error: `
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM11 15H9V13H11V15ZM11 11H9V5H11V11Z" fill="currentColor"/>
          </svg>
        `,
        info: `
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 0C4.48 0 0 4.48 0 10C0 15.52 4.48 20 10 20C15.52 20 20 15.52 20 10C20 4.48 15.52 0 10 0ZM11 15H9V9H11V15ZM11 7H9V5H11V7Z" fill="currentColor"/>
          </svg>
        `,
      };
      return icons[type];
    }

    private escapeHtml(text: string): string {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }
  }

  declare global {
    interface Window {
      toast: ToastManager;
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      window.toast = new ToastManager();
    });
  } else {
    window.toast = new ToastManager();
  }
</script>

<style is:global>
  .toast-stack {
    z-index: 9999;
    isolation: isolate;
  }

  .toast {
    --toast-rail: var(--color-flare);
    display: flex;
    align-items: stretch;
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border-med);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35),
      0 16px 48px rgba(0, 0, 0, 0.55);
    font-family: var(--font-primary, "Geist", sans-serif);
    font-size: 14px;
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: var(--color-content-85);
    transform: translateX(0);
    opacity: 1;
    transition:
      opacity 0.28s ease,
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .toast--hidden {
    opacity: 0;
    transform: translateX(12px);
    pointer-events: none;
  }

  .toast__rail {
    width: 3px;
    flex-shrink: 0;
    background: var(--toast-rail);
  }

  .toast--success {
    --toast-rail: var(--color-green);
  }

  .toast--error {
    --toast-rail: #ff3b3b;
    border-color: rgba(255, 59, 59, 0.28);
    box-shadow:
      0 0 0 1px rgba(255, 59, 59, 0.12),
      0 16px 48px rgba(0, 0, 0, 0.55);
  }

  .toast--info {
    --toast-rail: var(--color-content-40);
  }

  .toast__main {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    flex: 1;
    min-width: 0;
    padding: 14px 6px 14px 14px;
  }

  .toast__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: var(--color-content-45);
  }

  .toast--success .toast__icon {
    color: var(--color-green);
  }

  .toast--error .toast__icon {
    color: rgba(255, 59, 59, 0.92);
  }

  .toast--info .toast__icon {
    color: var(--color-content-55);
  }

  .toast__message {
    flex: 1;
    margin: 0;
    padding-top: 6px;
    padding-bottom: 2px;
  }

  .toast__close {
    flex-shrink: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    align-self: stretch;
    background: transparent;
    border: none;
    padding: 12px 12px 12px 4px;
    margin: 0;
    cursor: pointer;
    color: var(--color-content-30);
    transition: color 0.2s ease;
  }

  .toast__close:hover {
    color: var(--color-content-85);
  }

  .toast__close:focus-visible {
    outline: 2px solid var(--color-flare);
    outline-offset: -4px;
  }
</style>
