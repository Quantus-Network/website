---
import {
  SUPPORTED_LOCALES,
  getLocaleFromUrl,
  addLocaleToUrl,
  removeLocaleFromUrl,
} from "@/utils/i18n";

interface LocaleInfo {
  code: string;
  nativeName: string;
  flag: string;
}

const localeInfo: Record<string, LocaleInfo> = {
  "en-US": { code: "en-US", nativeName: "English", flag: "🇺🇸" },
  "zh-CN": { code: "zh-CN", nativeName: "中文", flag: "🇨🇳" },
  "ko-KR": { code: "ko-KR", nativeName: "한국어", flag: "🇰🇷" },
  "id-ID": { code: "id-ID", nativeName: "Bahasa Indonesia", flag: "🇮🇩" },
  "ja-JP": { code: "ja-JP", nativeName: "日本語", flag: "🇯🇵" },
  "ru-RU": { code: "ru-RU", nativeName: "Русский", flag: "🇷🇺" },
  "es-ES": { code: "es-ES", nativeName: "Español", flag: "🇪🇸" },
  "de-DE": { code: "de-DE", nativeName: "Deutsch", flag: "🇩🇪" },
  "hi-IN": { code: "hi-IN", nativeName: "हिन्दी", flag: "🇮🇳" },
};

const currentLocale = getLocaleFromUrl(Astro.url.pathname);
const currentPath = removeLocaleFromUrl(Astro.url.pathname);

export interface Props {
  id?: string;
  class?: string;
}

const { id = "language-switcher", class: className } = Astro.props;
---

<div class:list={["relative", className]}>
  <button
    id={id}
    type="button"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Choose language"
    class="font-mono group flex cursor-pointer items-center gap-2 border-none bg-transparent p-0 text-[11px] tracking-widest uppercase text-content-45 transition-colors duration-200 hover:text-[rgba(232,230,224,0.8)]"
  >
    <span class="text-sm leading-none">{localeInfo[currentLocale]?.flag}</span>
    <span>{localeInfo[currentLocale]?.nativeName}</span>
    <svg
      class="h-3 w-3 transition-transform duration-200 group-[.open]:rotate-180"
      viewBox="0 0 12 12"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M2.5 4.5L6 8L9.5 4.5"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="square"></path>
    </svg>
  </button>

  <ul
    id={`${id}-listbox`}
    role="listbox"
    aria-label="Language options"
    class="border-content-8 bg-void absolute bottom-full left-0 z-50 mb-2 hidden min-w-[160px] flex-col border py-1"
  >
    {
      SUPPORTED_LOCALES.map((locale) => (
        <li role="option" aria-selected={locale === currentLocale}>
          <a
            href={addLocaleToUrl(currentPath, locale)}
            class:list={[
              "font-mono flex items-center gap-2.5 px-4 py-2.5 text-[11px] tracking-widest uppercase no-underline transition-colors duration-150",
              locale === currentLocale
                ? "text-content-90 bg-[rgba(232,230,224,0.05)]"
                : "text-content-45 hover:text-content-70 hover:bg-[rgba(232,230,224,0.03)]",
            ]}
          >
            <span class="text-sm leading-none">{localeInfo[locale].flag}</span>
            <span>{localeInfo[locale].nativeName}</span>
            {locale === currentLocale && (
              <span class="bg-flare ml-auto h-1 w-1 shrink-0 rounded-full" />
            )}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  function initLanguageSwitcher(trigger: HTMLElement) {
    const listbox = document.getElementById(`${trigger.id}-listbox`);
    if (!listbox) return;

    function open() {
      trigger.classList.add("open");
      trigger.setAttribute("aria-expanded", "true");
      listbox!.classList.remove("hidden");
      listbox!.classList.add("flex");
    }

    function close() {
      trigger.classList.remove("open");
      trigger.setAttribute("aria-expanded", "false");
      listbox!.classList.add("hidden");
      listbox!.classList.remove("flex");
    }

    trigger.addEventListener("click", () => {
      const isOpen = trigger.getAttribute("aria-expanded") === "true";
      isOpen ? close() : open();
    });

    document.addEventListener("click", (e) => {
      if (
        !trigger.contains(e.target as Node) &&
        !listbox!.contains(e.target as Node)
      ) {
        close();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }

  document.querySelectorAll<HTMLElement>("[aria-haspopup='listbox']").forEach(initLanguageSwitcher);
</script>
