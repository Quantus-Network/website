---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class:list={["pointer-events-none absolute inset-0 overflow-hidden", className]}
  aria-hidden="true"
>
  <div
    class="absolute -bottom-[100px] -left-[100px] h-[500px] w-[500px] rounded-full"
    style="background: radial-gradient(circle, var(--flare-12) 0%, transparent 70%);"
  />
  <div
    class="absolute -top-20 -right-20 h-[450px] w-[450px] rounded-full"
    style="background: radial-gradient(circle, var(--flare-8) 0%, transparent 70%);"
  />
</div>
