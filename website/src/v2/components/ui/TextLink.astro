---
interface Props {
  href: string;
  target?: string;
  rel?: string;
  class?: string;
}

const { href, target, rel, class: className = "" } = Astro.props;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    "font-body-sm text-(--flare) underline decoration-(--flare-30) underline-offset-4 transition-colors hover:decoration-(--flare)",
    className,
  ]}
>
  <slot />
</a>
