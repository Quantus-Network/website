---
import Eyebrow from "./Eyebrow.astro";

interface Props {
  eyebrow: string;
  title: string;
  titleAs?: "h2" | "h3";
  eyebrowVariant?: "default" | "flare" | "muted";
  class?: string;
}

const {
  eyebrow,
  title,
  titleAs: TitleTag = "h2",
  eyebrowVariant = "default",
  class: className = "",
} = Astro.props;
---

<div class:list={["max-w-[1040px]", className]}>
  <Eyebrow variant={eyebrowVariant} class="mb-5">{eyebrow}</Eyebrow>
  <TitleTag class="font-display-lg text-(--white)">
    {title}
  </TitleTag>
</div>
