          fill="#FF6B35"
          opacity="0.7"></path>
      </svg>
      <!-- ML-DSA label -->
      <text
        x="130"
        y="282"
        font-family="Geist Mono, monospace"
        font-size="10"
        fill="rgba(232,230,224,0.25)"
        text-anchor="middle"
        letter-spacing="0.1em">ML-DSA-87</text
      >
      <!-- Home indicator -->
      <line
        x1="95"
        y1="455"
        x2="165"
        y2="455"
        stroke="rgba(232,230,224,0.2)"
        stroke-width="1.5"></line>
    </svg>
  </div>
</section>

<style is:global>
  .wallet-divider {
    width: 0;
    height: 1px;
    background: #ff6b35;
    margin-bottom: 0;
    margin-left: -52px;
    margin-right: -52px;
    transition: width 0.8s ease-out;
  }
  .wallet-divider.expanded {
    width: calc(100% + 104px);
  }
</style>

<style>
  #wallet-hero {
    position: relative;
    height: 100vh;
    background: #0e0e0e;
    display: grid;
    grid-template-columns: 55fr 45fr;
    align-items: center;
    padding: 0 52px 48px;
    overflow: hidden;
    z-index: 1;
  }

  #wallet-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(232, 230, 224, 0.12) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    -webkit-mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      transparent 30%,
      rgba(0, 0, 0, 0.6) 60%,
      black 100%
    );
    mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      transparent 30%,
      rgba(0, 0, 0, 0.6) 60%,
      black 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  #wallet-hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 320px;
    height: 320px;
    background:
      linear-gradient(to bottom, #ff6b35 1px, transparent 1px),
      linear-gradient(to right, #ff6b35 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.06;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: radial-gradient(
      circle at top right,
      black 0%,
      transparent 70%
    );
    mask-image: radial-gradient(circle at top right, black 0%, transparent 70%);
  }

  .wallet-hero-left {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .wallet-hero-right {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wallet-eyebrow {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ff6b35;
    display: block;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.5s ease 0.1s,
      transform 0.5s ease 0.1s;
  }
  .wallet-eyebrow.in {
    opacity: 1;
    transform: none;
  }

  .wallet-h1 {
    font-family: "Geist", sans-serif;
    font-size: clamp(36px, 4vw, 60px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.6s ease 0.25s,
      transform 0.6s ease 0.25s;
  }
  .wallet-h1.in {
    opacity: 1;
    transform: none;
  }
  .wallet-sub {
    font-family: "Geist", sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: rgba(232, 230, 224, 0.6);
    line-height: 1.6;
    max-width: 480px;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.5s ease 0.4s,
      transform 0.5s ease 0.4s;
  }
  .wallet-sub.in {
    opacity: 1;
    transform: none;
  }
  .wallet-cta-row {
    display: flex;
    gap: 16px;
    opacity: 0;
    transition: opacity 0.5s ease 0.55s;
  }
  .wallet-cta-row.in {
    opacity: 1;
  }

  .wallet-btn-primary {
    font-family: "Geist Mono", monospace;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: #ff6b35;
    color: #0e0e0e;
    border: 1px solid #ff6b35;
    padding: 14px 32px;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.18s;
    white-space: nowrap;
  }
  .wallet-btn-primary:hover {
    opacity: 0.88;
  }

  .wallet-btn-secondary {
    font-family: "Geist Mono", monospace;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: transparent;
    color: rgba(232, 230, 224, 0.7);
    border: 1px solid rgba(232, 230, 224, 0.2);
    padding: 14px 32px;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.18s;
    white-space: nowrap;
  }
  .wallet-btn-secondary:hover {
    border-color: rgba(232, 230, 224, 0.5);
  }

  @media (max-width: 768px) {
    #wallet-hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 100vh;
      padding: 100px 24px 60px;
    }
    .wallet-hero-right {
      display: none;
    }
    .wallet-h1 {
      font-size: clamp(30px, 8vw, 44px);
    }
    .wallet-sub {
      font-size: 16px;
    }
    .wallet-cta-row {
      flex-direction: column;
    }
    .wallet-btn-primary,
    .wallet-btn-secondary {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  const eyebrow = document.getElementById("wallet-eyebrow")!;
  const h1 = document.getElementById("wallet-h1")!;
  const sub = document.getElementById("wallet-sub")!;
  const ctaRow = document.getElementById("wallet-cta-row")!;

  // Nav visible
  window.addEventListener("load", () => {
    // Hero entrance
    setTimeout(() => eyebrow.classList.add("in"), 100);
    setTimeout(() => h1.classList.add("in"), 250);
    setTimeout(() => sub.classList.add("in"), 400);
    setTimeout(() => ctaRow.classList.add("in"), 550);
  });

  // Orange dividers expand on scroll
  document.querySelectorAll(".wallet-divider").forEach((el) => {
    new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) {
          el.classList.add("expanded");
        }
      },
      { threshold: 0.1 },
    ).observe(el);
  });

  // Scroll animations
  document.querySelectorAll<HTMLElement>(".wallet-animate").forEach((el) => {
    new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) {
          const delay = el.dataset.delay || "0";
          el.style.transitionDelay = delay + "s";
          el.classList.add("in");
        }
      },
      { threshold: 0.15 },
    ).observe(el);
  });
</script>
