---
import { APP_LINKS } from "@/constants/app-links";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="wallet-hero">
  <div class="wallet-hero-left">
    <span class="wallet-eyebrow" id="wallet-eyebrow">
      {t("v2.wallet.hero_banner.eyebrow")}
    </span>
    <h1 class="wallet-h1" id="wallet-h1">
      {t("v2.wallet.hero_banner.title")}
    </h1>
    <p class="wallet-sub" id="wallet-sub">
      {t("v2.wallet.hero_banner.sub")}
    </p>
    <div class="wallet-cta-row" id="wallet-cta-row">
      <a
        href={APP_LINKS.ios}
        class="wallet-btn-primary"
        target="_blank"
        rel="noopener"
      >
        {t("v2.wallet.hero_banner.cta_app_store")}
      </a>
      <a
        href={APP_LINKS.android}
        class="wallet-btn-secondary"
        target="_blank"
        rel="noopener"
      >
        {t("v2.wallet.hero_banner.cta_google_play")}
      </a>
    </div>
  </div>
  <div class="wallet-hero-right">
    <svg
      width="260"
      height="480"
      viewBox="0 0 260 480"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <!-- Outer phone rect -->
      <rect
        x="10"
        y="10"
        width="240"
        height="460"
        stroke="rgba(232,230,224,0.15)"
        stroke-width="1"
        fill="none"></rect>
      <!-- Corner dots -->
      <circle cx="10" cy="10" r="2.5" fill="rgba(232,230,224,0.3)"></circle>
      <circle cx="250" cy="10" r="2.5" fill="rgba(232,230,224,0.3)"></circle>
      <circle cx="250" cy="470" r="2.5" fill="rgba(232,230,224,0.3)"></circle>
      <circle cx="10" cy="470" r="2.5" fill="rgba(232,230,224,0.3)"></circle>
      <!-- Dynamic island -->
      <rect x="90" y="16" width="80" height="10" fill="rgba(232,230,224,0.1)"
      ></rect>
      <!-- Inner screen rect -->
      <rect
        x="22"
        y="30"
        width="216"
        height="380"
        stroke="rgba(232,230,224,0.08)"
        stroke-width="0.75"
        fill="none"></rect>
      <!-- Dashed horizontal centre line across screen -->
      <line
        x1="22"
        y1="220"
        x2="238"
        y2="220"
        stroke="rgba(232,230,224,0.05)"
        stroke-width="0.75"
        stroke-dasharray="3,4"></line>
      <!-- Quantus Q logomark -->
      <svg x="83" y="173" width="94" height="94" viewBox="0 0 1000 1000">
        <path
          d="M790.222 937.76L471.492 618.74L525.412 564.82L844.142 883.84L790.222 937.76Z"
          fill="#FF6B35"
          opacity="0.7"></path>
        <path
          d="M565.016 525.22L618.916 471.32L937.696 790.29L883.766 844.22L565.016 525.22Z"
          fill="#FF6B35"
          opacity="0.7"></path>
