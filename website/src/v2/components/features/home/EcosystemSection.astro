---
import { APP_LINKS } from "@/constants/app-links";
import { createTranslator, getLocaleFromUrl } from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<section id="ecosystem">
  <div class="ecosystem-divider"></div>

  <div class="eco-inner">
    <span class="eco-eyebrow">
      {t("v2.home.ecosystem.eyebrow")}
    </span>
    <h2 class="eco-headline">
      {t("v2.home.ecosystem.headline")}
    </h2>

    <div class="eco-grid">
      <!-- CARD 1: WALLET -->
      <div class="eco-card">
        <div>
          <span class="eco-card-label">
            {t("v2.home.ecosystem.cards.wallet.label")}
          </span>
          <p class="eco-card-desc">
            {t("v2.home.ecosystem.cards.wallet.description")}
          </p>
        </div>
        <div class="eco-card-mid">
          <svg
            id="phone-svg"
            viewBox="0 0 120 180"
            width="100"
            height="160"
            style="display:block;margin:auto"
          >
            <!-- Phone outline (animated) -->
            <rect
              id="phone-outline"
              x="15"
              y="5"
              width="90"
              height="170"
              rx="0"
              stroke="rgba(232,230,224,0.2)"
              stroke-width="1"
              fill="none"
              stroke-dasharray="520"
              stroke-dashoffset="520"></rect>
            <!-- Corner dots -->
            <circle cx="15" cy="5" r="2" fill="rgba(232,230,224,0.3)"></circle>
            <circle cx="105" cy="5" r="2" fill="rgba(232,230,224,0.3)"></circle>
            <circle cx="15" cy="175" r="2" fill="rgba(232,230,224,0.3)"
            ></circle>
            <circle cx="105" cy="175" r="2" fill="rgba(232,230,224,0.3)"
            ></circle>
            <!-- Screen area -->
            <rect
              x="22"
              y="18"
              width="76"
              height="120"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"
              fill="none"></rect>
            <!-- Screen corner dots -->
            <circle cx="22" cy="18" r="1.5" fill="rgba(232,230,224,0.2)"
            ></circle>
            <circle cx="98" cy="18" r="1.5" fill="rgba(232,230,224,0.2)"
            ></circle>
            <circle cx="22" cy="138" r="1.5" fill="rgba(232,230,224,0.2)"
            ></circle>
            <circle cx="98" cy="138" r="1.5" fill="rgba(232,230,224,0.2)"
            ></circle>
            <!-- Dashed centre line -->
            <line
              x1="60"
              y1="18"
              x2="60"
              y2="138"
              stroke="rgba(232,230,224,0.08)"
              stroke-width="0.75"
              stroke-dasharray="3,3"></line>
            <!-- Q logomark -->
            <svg
              id="phone-q"
              x="43"
              y="64"
              width="34"
              height="34"
              viewBox="0 0 1000 1000"
            >
              <g>
                <path
                  d="M790.222 937.76L471.492 618.74L525.412 564.82L844.142 883.84L790.222 937.76Z"
                  fill="#FF6B35"
                  opacity="0.7"></path>
                <path
                  d="M565.016 525.22L618.916 471.32L937.696 790.29L883.766 844.22L565.016 525.22Z"
                  fill="#FF6B35"
                  opacity="0.7"></path>
                <path
                  d="M903.956 365.46C901.596 353.71 898.756 342.14 895.466 330.78C864.066 219.98 790.696 130.06 697.576 72.2299C610.336 16.8299 505.046 -10.3101 398.176 3.59991C379.086 5.95991 359.996 9.60993 341.016 14.6199C276.886 31.1899 214.526 63.1 158.386 112.58C158.326 112.63 158.266 112.68 158.216 112.73C157.896 113.01 157.576 113.3 157.266 113.58C156.386 114.36 155.496 115.15 154.616 115.95C154.176 116.35 153.736 116.74 153.306 117.14C152.476 117.9 151.636 118.66 150.806 119.42C150.036 120.12 149.276 120.83 148.516 121.54C148.166 121.87 147.806 122.2 147.456 122.53C145.146 124.69 142.856 126.86 140.606 129.04C134.966 134.41 129.376 139.97 123.856 145.71C119.686 150.26 115.626 154.85 111.676 159.47C65.6956 212.13 35.0656 270.04 17.9056 329.64C12.5856 347.7 8.51561 365.86 5.64561 384.04C-13.3644 500.24 16.7356 615.1 79.3456 707.94C142.986 804.55 241.746 878.24 362.076 903.15C372.956 905.47 383.986 907.37 395.166 908.86C449.216 916.31 506.276 913.73 564.626 898.96C566.856 898.44 569.086 897.91 571.316 897.35V897.33C575.706 896.18 580.106 894.97 584.486 893.68L584.346 893.51C587.956 892.43 591.576 891.3 595.196 890.13C602.336 887.88 609.506 885.46 616.686 882.85L616.666 882.83C620.926 881.22 625.176 879.56 629.396 877.82L629.256 877.68C634.646 875.49 640.046 873.19 645.446 870.78L557.356 782.61C556.156 782.98 554.966 783.36 553.756 783.71L553.706 783.66C548.926 785.12 544.146 786.46 539.356 787.69H539.346C534.546 788.87 529.726 789.96 524.866 790.94L524.816 790.89C517.206 792.51 509.596 793.85 502.006 794.91C497.886 795.46 493.746 795.95 489.596 796.34L489.556 796.29C478.926 797.41 468.356 798 457.876 798.09C389.056 798.23 322.366 776.92 266.416 739.46C255.356 732.02 244.726 723.94 234.586 715.29C186.566 674.04 149.766 619.83 130.376 558.36C126.116 544.53 122.726 530.28 120.276 515.64C119.466 511.34 118.756 507.04 118.136 502.74C117.426 497.24 116.836 491.7 116.396 486.12C115.986 481.98 115.666 477.84 115.426 473.72C115.086 466.04 115.016 458.3 115.226 450.5C115.366 430.88 117.266 411.64 120.756 392.92C131.666 336.67 156.876 284.22 192.696 240.38C243.546 178.85 315.276 135.04 395.136 120.25C405.506 118.42 416.046 117.09 426.746 116.26C432.176 115.74 437.586 115.36 442.976 115.11C447.466 114.97 451.976 114.92 456.516 114.97C461.226 114.93 465.916 115 470.586 115.15C477.786 115.5 485.016 116.09 492.276 116.93C515.016 119.13 536.946 123.59 557.916 130.04C618.436 149.12 672.046 185.03 713.196 231.99C713.746 232.62 714.296 233.25 714.846 233.89C714.996 234.06 715.136 234.23 715.286 234.4C722.166 242.44 728.686 250.79 734.816 259.43C771.136 310.87 793.586 372.03 797.686 436.02C797.716 436.58 797.756 437.15 797.786 437.71C798.796 457.06 798.126 476.79 795.606 496.72L795.776 496.87C794.566 506.6 792.916 516.36 790.806 526.13L791.056 526.38C788.846 536.73 786.106 547.08 782.846 557.39L870.806 645.42C874.926 636.13 878.726 626.86 882.216 617.6L882.466 617.85C885.106 610.5 887.566 603.18 889.846 595.88C891.576 590.56 893.206 585.26 894.736 579.96L894.906 580.1C895.636 577.33 896.336 574.57 897.016 571.81C916.416 499.99 917.406 430.17 903.956 365.43V365.46Z"
                  fill="#FF6B35"
                  opacity="0.7"></path>
              </g>
            </svg>
            <!-- Home indicator -->
            <line
              x1="45"
              y1="158"
              x2="75"
              y2="158"
              stroke="rgba(232,230,224,0.25)"
              stroke-width="1.5"></line>
          </svg>
        </div>
        <div class="eco-card-bot">
          <div class="eco-beta-tag">
            <div class="eco-beta-dot"></div>
            {t("v2.home.ecosystem.cards.wallet.beta")}
          </div>
          <div class="eco-dl-tags">
            <a
              href={APP_LINKS.ios}
              target="_blank"
              rel="noopener"
              class="eco-dl-tag"
            >
              {t("v2.home.ecosystem.cards.wallet.app_store")}
            </a>
            <a
              href={APP_LINKS.android}
              target="_blank"
              rel="noopener"
              class="eco-dl-tag"
            >
              {t("v2.home.ecosystem.cards.wallet.google_play")}
            </a>
          </div>
        </div>
      </div>

      <!-- CARD 2: TECHNOLOGY -->
      <div class="eco-card">
        <div>
          <span class="eco-card-label">
            {t("v2.home.ecosystem.cards.technology.label")}
          </span>
          <p class="eco-card-desc">
            {t("v2.home.ecosystem.cards.technology.description")}
          </p>
        </div>
        <div class="eco-card-mid">
          <svg
            id="lattice-svg"
            viewBox="0 0 160 140"
            width="140"
            height="120"
            style="display:block;margin:auto"
          >
            <!-- Grid lines and nodes built by JS -->
          </svg>
        </div>
        <div class="eco-card-bot">
          <div class="eco-beta-tag" style="color:rgba(232,230,224,0.35);">
            <div
              class="eco-beta-dot"
              style="background:rgba(232,230,224,0.35);animation:none;"
            >
            </div>
            {t("v2.home.ecosystem.cards.technology.nist_badge")}
          </div>
          <div class="eco-dl-tags">
            <a href="/v2/whitepaper" class="eco-dl-tag">
              {t("v2.home.ecosystem.cards.technology.whitepaper_cta")}
            </a>
          </div>
        </div>
      </div>

      <!-- CARD 3: NETWORK -->
      <div class="eco-card">
        <div>
          <span class="eco-card-label">
            {t("v2.home.ecosystem.cards.network.label")}
          </span>
          <p class="eco-card-desc">
            {t("v2.home.ecosystem.cards.network.description")}
          </p>
        </div>
        <div class="eco-card-mid">
          <svg
            id="network-svg"
            viewBox="0 0 160 140"
            width="140"
            height="120"
            style="display:block;margin:auto"
          >
            <!-- Cross connections (dashed) -->
            <line
              x1="30"
              y1="30"
              x2="130"
              y2="30"
              stroke="rgba(232,230,224,0.07)"
              stroke-width="0.5"
              stroke-dasharray="2,3"></line>
            <line
              x1="20"
              y1="75"
              x2="140"
              y2="75"
              stroke="rgba(232,230,224,0.07)"
              stroke-width="0.5"
              stroke-dasharray="2,3"></line>
            <line
              x1="40"
              y1="120"
              x2="120"
              y2="120"
              stroke="rgba(232,230,224,0.07)"
              stroke-width="0.5"
              stroke-dasharray="2,3"></line>
            <!-- Spoke lines (animated) -->
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="30"
              y2="30"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="130"
              y2="30"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="20"
              y2="75"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="140"
              y2="75"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="40"
              y2="120"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <line
              class="net-spoke"
              x1="80"
              y1="70"
              x2="120"
              y2="120"
              stroke="rgba(232,230,224,0.12)"
              stroke-width="0.75"></line>
            <!-- Outer nodes -->
            <circle
              cx="30"
              cy="30"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <circle
              cx="130"
              cy="30"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <circle
              cx="20"
              cy="75"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <circle
              cx="140"
              cy="75"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <circle
              cx="40"
              cy="120"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <circle
              cx="120"
              cy="120"
              r="3"
              fill="rgba(232,230,224,0.2)"
              stroke="rgba(232,230,224,0.3)"
              stroke-width="0.75"></circle>
            <!-- Central node (pulsing) -->
            <circle
              id="net-centre"
              cx="80"
              cy="70"
              r="6"
              fill="rgba(255,107,53,0.3)"
              stroke="#FF6B35"
              stroke-width="1"></circle>
          </svg>
        </div>
        <div class="eco-card-bot">
          <div
            class="eco-beta-tag"
            style="color:rgba(232,230,224,0.35);letter-spacing:0.14em;"
          >
            <div
              class="eco-beta-dot"
              style="background:rgba(232,230,224,0.35);animation:none;"
            >
            </div>
            {t("v2.home.ecosystem.cards.network.validators")}
          </div>
          <div class="eco-dl-tags">
            <a href="#" class="eco-dl-tag">
              {t("v2.home.ecosystem.cards.network.explorer_cta")}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div><!-- /.eco-inner -->
</section>

<style>
  #ecosystem {
    background: #0e0e0e;
    position: relative;
    z-index: 50;
    padding: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  #ecosystem.eco-visible {
    opacity: 1;
  }
  .eco-inner {
    padding: 120px 52px 120px;
  }
  .eco-eyebrow {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232, 230, 224, 0.35);
    display: block;
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(20px);
  }
  .eco-eyebrow.in {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s ease 0s,
      transform 0.7s ease 0s;
  }
  .eco-headline {
    font-family: "Geist", sans-serif;
    font-size: 52px;
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin-bottom: 64px;
    opacity: 0;
    transform: translateY(20px);
  }
  .eco-headline.in {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s ease 0.15s,
      transform 0.7s ease 0.15s;
  }

  /* Divider */
  .ecosystem-divider {
    width: 0;
    height: 1px;
    background: #ff6b35;
    transition: width 0.8s ease-out;
    margin: 0;
    padding: 0;
    display: block;
  }
  .ecosystem-divider.expanded {
    width: 100%;
  }

  /* Grid */
  .eco-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .eco-card {
    background: #0e0e0e;
    padding: 40px 36px 32px;
    height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(232, 230, 224, 0.08);
    transition: border-color 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
  }
  .eco-card:hover {
    border-color: #ff6b35;
  }
  .eco-card.in-1 {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s ease 0.3s,
      transform 0.7s ease 0.3s,
      border-color 0.3s ease;
  }
  .eco-card.in-2 {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s ease 0.45s,
      transform 0.7s ease 0.45s,
      border-color 0.3s ease;
  }
  .eco-card.in-3 {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s ease 0.6s,
      transform 0.7s ease 0.6s,
      border-color 0.3s ease;
  }

  .eco-card-label {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ff6b35;
    display: block;
    margin-bottom: 16px;
  }
  .eco-card-desc {
    font-family: "Geist", sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: rgba(232, 230, 224, 0.85);
    line-height: 1.4;
  }
  .eco-card-mid {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 16px 0;
  }
  .eco-card-bot {
    margin-top: auto;
    flex-shrink: 0;
  }

  /* Card 1 bottom */
  .eco-beta-tag {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4ade80;
  }
  .eco-beta-dot {
    width: 4px;
    height: 4px;
    background: #4ade80;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pd 2s ease infinite;
  }
  .eco-dl-tags {
    margin-top: 12px;
  }
  .eco-dl-tag {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(232, 230, 224, 0.5);
    border: 1px solid rgba(232, 230, 224, 0.15);
    padding: 6px 14px;
    display: inline-block;
    margin-right: 8px;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .eco-dl-tag:hover {
    border-color: rgba(232, 230, 224, 0.4);
    color: rgba(232, 230, 224, 0.9);
    text-decoration: none;
  }

  /* Card 2 bottom */
  .eco-cert-tag {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 230, 224, 0.35);
    display: block;
  }
  .eco-wp-link {
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    font-weight: 400;
    color: rgba(255, 107, 53, 0.7);
    display: block;
    margin-top: 8px;
    text-decoration: none;
    transition: color 0.2s;
  }
  .eco-wp-link:hover {
    color: #ff6b35;
  }

  /* Card 2 mainnet tag */
  .eco-mainnet-tag {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 107, 53, 0.7);
  }
  .eco-mainnet-dot {
    width: 4px;
    height: 4px;
    background: #ff6b35;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pd 2s ease infinite;
  }
  .eco-testnet-tag {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 107, 53, 0.7);
    margin-top: 10px;
  }
  .eco-testnet-dot {
    width: 4px;
    height: 4px;
    background: #ff6b35;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pd 2s ease infinite;
  }

  /* Lattice node animation */
  .lattice-node {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .lattice-node.lit {
    opacity: 1;
  }
  .accent-node {
    transition: r 0.3s ease;
  }

  /* Hover: wallet phone Q pulse */
  @keyframes q-pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }
  .eco-card:hover #phone-q {
    animation: q-pulse 0.8s ease-in-out infinite;
  }

  /* Hover: lattice node pulse (opacity only — no transform/scale) */
  @keyframes node-pulse {
    0%,
    100% {
      opacity: 0.25;
    }
    50% {
      opacity: 0.7;
    }
  }
  .lattice-node.pulsing {
    animation: node-pulse 1.5s ease-in-out infinite;
  }
  .eco-card:hover .accent-node {
    stroke-opacity: 1;
  }

  /* Hover: network line flow */
  @keyframes flow {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: -20;
    }
  }
  .eco-card:hover .net-spoke {
    animation: flow 1s linear infinite;
  }

  @media (max-width: 768px) {
    .eco-inner {
      padding: 60px 24px;
    }

    .eco-headline {
      font-size: 32px;
      margin-bottom: 40px;
    }

    .eco-grid {
      grid-template-columns: 1fr;
    }

    .eco-card {
      height: auto;
      min-height: 320px;
    }
  }
</style>

<script>
  const ecoSection = document.getElementById("ecosystem")!;
  const ecoDivider = ecoSection.querySelector(".ecosystem-divider")!;
  const ecoEyebrow = ecoSection.querySelector(".eco-eyebrow")!;
  const ecoHeadline = ecoSection.querySelector(".eco-headline")!;
  const ecoCards = ecoSection.querySelectorAll(".eco-card");

  const phoneOutline = document.getElementById("phone-outline")!;
  const latticeSvg = document.getElementById("lattice-svg")!;
  const techCard = ecoCards[1];
  const spokes = document.querySelectorAll(".net-spoke");
  const netCentre = document.getElementById("net-centre")!;

  /* ── Build lattice SVG ── */
  const cols = 5,
    rows = 4,
    hGap = 32,
    vGap = 28,
    ox = 16,
    oy = 14;
  const ns = "http://www.w3.org/2000/svg";
  const nodePositions = [];

  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const x = ox + c * hGap,
        y = oy + r * vGap;
      nodePositions.push({ x, y });
      // Right connection
      if (c < cols - 1) {
        const l = document.createElementNS(ns, "line");
        l.setAttribute("x1", x.toString());
        l.setAttribute("y1", y.toString());
        l.setAttribute("x2", (x + hGap).toString());
        l.setAttribute("y2", y.toString());
        l.setAttribute("stroke", "rgba(232,230,224,0.12)");
        l.setAttribute("stroke-width", "0.75");
        latticeSvg.appendChild(l);
      }
      // Bottom connection
      if (r < rows - 1) {
        const l = document.createElementNS(ns, "line");
        l.setAttribute("x1", x.toString());
        l.setAttribute("y1", y.toString());
        l.setAttribute("x2", x.toString());
        l.setAttribute("y2", (y + vGap).toString());
        l.setAttribute("stroke", "rgba(232,230,224,0.12)");
        l.setAttribute("stroke-width", "0.75");
        latticeSvg.appendChild(l);
      }
      // Diagonal (every other cell)
      if (c < cols - 1 && r < rows - 1 && (c + r) % 2 === 0) {
        const l = document.createElementNS(ns, "line");
        l.setAttribute("x1", x.toString());
        l.setAttribute("y1", y.toString());
        l.setAttribute("x2", (x + hGap).toString());
        l.setAttribute("y2", (y + vGap).toString());
        l.setAttribute("stroke", "rgba(232,230,224,0.07)");
        l.setAttribute("stroke-width", "0.5");
        l.setAttribute("stroke-dasharray", "2,3");
        latticeSvg.appendChild(l);
      }
    }
  }
  // Accent nodes
  [
    [48, 42],
    [112, 70],
    [80, 98],
  ].forEach(([x, y]) => {
    const c = document.createElementNS(ns, "circle");
    c.setAttribute("cx", x.toString());
    c.setAttribute("cy", y.toString());
    c.setAttribute("r", "3");
    c.setAttribute("stroke", "#FF6B35");
    c.setAttribute("stroke-width", "1");
    c.setAttribute("fill", "rgba(255,107,53,0.15)");
    c.classList.add("accent-node");
    latticeSvg.appendChild(c);
  });
  // Regular nodes (on top of lines)
  const latticeNodes: SVGCircleElement[] = [];
  nodePositions.forEach(({ x, y }) => {
    const c = document.createElementNS(ns, "circle");
    c.setAttribute("cx", x.toString());
    c.setAttribute("cy", y.toString());
    c.setAttribute("r", "2");
    c.setAttribute("fill", "rgba(232,230,224,0.25)");
    c.classList.add("lattice-node");
    latticeSvg.appendChild(c);
    latticeNodes.push(c);
  });

  /* ── Lattice card hover: opacity pulse only ── */
  techCard.addEventListener("mouseenter", () => {
    latticeNodes.forEach((n) => n.classList.add("pulsing"));
  });
  techCard.addEventListener("mouseleave", () => {
    latticeNodes.forEach((n) => n.classList.remove("pulsing"));
  });

  /* ── Set spoke dash lengths ── */
  spokes.forEach((spoke) => {
    const x1 = +spoke.getAttribute("x1")!,
      y1 = +spoke.getAttribute("y1")!;
    const x2 = +spoke.getAttribute("x2")!,
      y2 = +spoke.getAttribute("y2")!;

    const len = Math.sqrt((x2 - x1) ** 2 + (y2 - y1) ** 2);

    spoke.setAttribute("stroke-dasharray", len.toString());
    spoke.setAttribute("stroke-dashoffset", len.toString());
  });

  /* ── Central node pulse animation ── */
  let pulseDir = 1,
    pulseVal = 0.3;
  function pulseCentre() {
    pulseVal += pulseDir * 0.012;

    if (pulseVal >= 1) {
      pulseVal = 1;
      pulseDir = -1;
    }
    if (pulseVal <= 0.3) {
      pulseVal = 0.3;
      pulseDir = 1;
    }

    netCentre.setAttribute("opacity", pulseVal.toString());
    requestAnimationFrame(pulseCentre);
  }
  pulseCentre();

  /* ── Section fade-in on scroll (after #solution) ── */
  const ecoFadeObs = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        ecoSection.classList.add("eco-visible");
        ecoFadeObs.disconnect();
      }
    },
    { threshold: 0.1 },
  );
  ecoFadeObs.observe(ecoSection);

  /* ── IntersectionObserver ── */
  let animated = false;
  const ecoObs = new IntersectionObserver(
    (entries) => {
      if (entries[0].intersectionRatio >= 0.1 && !animated) {
        animated = true;
        ecoObs.disconnect();

        // Divider first
        ecoDivider.classList.add("expanded");

        // Eyebrow + headline
        ecoEyebrow.classList.add("in");
        ecoHeadline.classList.add("in");

        // Cards
        ecoCards[0].classList.add("in-1");
        ecoCards[1].classList.add("in-2");
        ecoCards[2].classList.add("in-3");

        // Phone outline draw
        setTimeout(() => {
          phoneOutline.style.transition = "stroke-dashoffset 1.8s ease-in-out";
          phoneOutline.style.strokeDashoffset = "0";
        }, 200);

        // Lattice nodes stagger
        latticeNodes.forEach((node, i) => {
          setTimeout(() => node.classList.add("lit"), i * 40);
        });

        // Network spokes stagger
        spokes.forEach((spoke, i) => {
          const spokeElement = spoke as SVGLineElement;

          setTimeout(
            () => {
              spokeElement.style.transition = "stroke-dashoffset 0.8s ease-out";
              spokeElement.style.strokeDashoffset = "0";
            },
            300 + i * 150,
          );
        });
      }
    },
    { threshold: 0.1 },
  );
  ecoObs.observe(ecoSection);
</script>
