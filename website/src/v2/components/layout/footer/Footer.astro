---
import { FOOTER_NAVIGATIONS } from "@/constants/footer-navigations";
import { applyStyles } from "@/utils/apply-styles";
import {
  createTranslator,
  getLocaleFromUrl,
  getLocalizedPath,
} from "@/utils/i18n";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);

const year = new Date().getFullYear();

const currentPath = Astro.url.pathname;
const isCurrentPage = (href: string) =>
  currentPath === getLocalizedPath(locale, href);
---

<footer
  id="footer"
  class="border-content-8 bg-void relative z-50 grid min-h-[calc(100vh-66px)] grid-cols-1 overflow-hidden border-t md:grid-cols-2"
>
  <!-- Background Glows -->
  <div
    class="pointer-events-none absolute -bottom-[100px] -left-[100px] z-0 h-[500px] w-[500px] bg-[radial-gradient(circle,var(--flare-12)_0%,transparent_70%)]"
  >
  </div>
  <div
    class="pointer-events-none absolute -top-[80px] -right-[80px] z-0 h-[450px] w-[450px] bg-[radial-gradient(circle,var(--flare-8)_0%,transparent_70%)]"
  >
  </div>

  <!-- Left Column -->
  <div
    class="border-content-8 relative z-10 flex flex-col justify-between border-b p-6 md:border-r md:border-b-0 md:p-[52px]"
  >
    <a
      href={getLocalizedPath(locale, "/")}
      class="text-content-25 font-mono text-[clamp(32px,10vw,56px)] leading-none font-light tracking-[0.05em] no-underline md:text-[clamp(48px,6vw,80px)]"
    >
      {t("v2.footer.brand")}
    </a>
    <div class="mt-8 flex flex-col gap-2 md:mt-0">
      <span class="text-content-25 font-mono text-xs tracking-[0.08em]">
        {t("v2.footer.copyright", { year })}
      </span>
      <span class="text-content-25 font-mono text-xs tracking-[0.08em]">
        {t("v2.footer.rights")}
      </span>
    </div>
  </div>

  <!-- Right Column -->
  <div class="relative z-10 flex flex-col justify-between p-6 md:p-[52px]">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-3 md:gap-10">
      {
        FOOTER_NAVIGATIONS.map((section) => (
          <div class="flex flex-col">
            <span class="text-content-30 mb-6 block font-mono text-xs tracking-[0.16em] uppercase">
              {t(section.label)}
            </span>
            {section.children.map((link) => (
              <a
                href={
                  link.href.startsWith("http")
                    ? link.href
                    : getLocalizedPath(locale, link.href)
                }
                target={link.target}
                rel={link.rel}
                class={applyStyles(
                  "text-content-55 hover:text-content-90 mb-3.5 block text-[13px] no-underline transition-colors duration-200",
                  isCurrentPage(link.href) && "text-content-90",
                )}
              >
                {t(link.label)}
              </a>
            ))}
          </div>
        ))
      }
    </div>
    <div class="mt-10 flex flex-col gap-1 md:mt-0">
      <span class="text-content-20 font-mono text-xs tracking-[0.12em]">
        {t("v2.footer.built_on")}
      </span>
    </div>
  </div>
</footer>
