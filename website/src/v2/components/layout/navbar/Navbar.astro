---
import LogoLong from "@/v2/assets/brand/logo-long.svg";
import {
  createTranslator,
  getLocaleFromUrl,
  getLocalizedPath,
} from "@/utils/i18n";
import { SITE_NAVIGATIONS } from "@/v2/constants/site-navigations";
import Button from "../../ui/Button.astro";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<nav
  id="navbar"
  class="bg-navbar border-border px-content-edges-mobile lg:px-content-edges [&.scrolled]:bg-navbar-scrolled] fixed top-0 right-0 left-0 z-1000 flex items-center justify-between border-b py-4 opacity-0 backdrop-blur-xs transition-all duration-500 ease-in-out lg:py-5 [&.scrolled]:backdrop-blur-md [&.visible]:opacity-100"
>
  <a href={getLocalizedPath(locale, "/")} class="block leading-none">
    <LogoLong class="block h-[26px] w-auto" />
  </a>

  <ul
    class="nav-links absolute left-1/2 hidden -translate-x-1/2 list-none gap-4 lg:flex xl:gap-8"
  >
    {
      SITE_NAVIGATIONS.map((item) => (
        <li>
          <a
            href={getLocalizedPath(locale, item.href)}
            class="after:bg-flare font-navbar-link text-muted relative no-underline transition-all duration-200 ease-in-out after:absolute after:bottom-[-2px] after:left-0 after:h-px after:w-0 after:transition-all after:duration-250 after:content-[''] hover:text-white hover:opacity-100 hover:after:w-full [&.nav-active]:text-white [&.nav-active]:after:bottom-[-4px] [&.nav-active]:after:h-[2px] [&.nav-active]:after:w-full"
          >
            {t(item.label)}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="flex items-center gap-4">
    <Button
      class="wallet-cta-link hidden lg:block"
      target="_blank"
      rel="noopener"
      variant="outline"
      size="small">{t("v2.navbar.download_wallet")}</Button
    >

    <button
      class="nav-hamburger group flex h-9 w-9 cursor-pointer items-center justify-center border-none bg-none p-1 lg:hidden"
      id="nav-hamburger"
      aria-label={t("v2.navbar.open_menu")}
      aria-expanded="false"
    >
      <svg
        class="hamburger-icon group-[.open]:hidden"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="3"
          y1="6"
          x2="21"
          y2="6"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="3"
          y1="12"
          x2="21"
          y2="12"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="3"
          y1="18"
          x2="21"
          y2="18"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
      </svg>

      <svg
        class="close-icon hidden group-[.open]:block"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="4"
          y1="4"
          x2="20"
          y2="20"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="20"
          y1="4"
          x2="4"
          y2="20"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
      </svg>
    </button>
  </div>
</nav>

<div
  class="mobile-menu bg-void fixed inset-0 z-999 hidden flex-col gap-8 px-8 pt-20 pb-10"
  id="mobile-nav-menu"
>
  <div class="mobile-menu-links flex flex-1 flex-col">
    {
      SITE_NAVIGATIONS.map((item) => (
        <a
          href={getLocalizedPath(locale, item.href)}
          class="font-navbar-link-mobile text-content border-content-10 flex items-center justify-between border-b py-[18px]"
        >
          {t(item.label)}
        </a>
      ))
    }
  </div>

  <Button
    class="wallet-cta-link py-[14px]"
    target="_blank"
    rel="noopener"
    variant="primary">{t("v2.navbar.download_wallet")}</Button
  >
</div>

<script>
  const hamburger = document.getElementById("nav-hamburger");
  const mobileMenu = document.getElementById("mobile-nav-menu");

  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.classList.add("flex");
    hamburger?.classList.add("open");
    hamburger?.setAttribute("aria-expanded", "true");
    const closeLabel = hamburger?.getAttribute("data-aria-close");
    if (closeLabel) hamburger?.setAttribute("aria-label", closeLabel);
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    mobileMenu?.classList.remove("flex");
    hamburger?.classList.remove("open");
    hamburger?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  document.addEventListener("click", (e) => {
    if (
      mobileMenu &&
      !mobileMenu.classList.contains("hidden") &&
      !mobileMenu.contains(e.target as Node) &&
      !hamburger?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  const nav = document.getElementById("navbar") as HTMLElement;
  window.addEventListener("scroll", () => {
    if (window.scrollY > window.innerHeight * 0.5) {
      nav.classList.add("scrolled");
    } else {
      nav.classList.remove("scrolled");
    }
  });

  setTimeout(() => nav.classList.add("visible"), 100);
</script>

<script>
  import { getWalletLink } from "@/v2/scripts/shared/get-wallet-link";

  window.addEventListener("load", () => {
    const walletLink = getWalletLink();

    document.querySelectorAll(".wallet-cta-link").forEach((el) => {
      (el as HTMLAnchorElement).href = walletLink;
    });
  });
</script>
