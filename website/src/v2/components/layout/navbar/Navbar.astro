---
import LogoLong from "@/v2/assets/brand/logo-long.svg";
import {
  createTranslator,
  getLocaleFromUrl,
  getLocalizedPath,
} from "@/utils/i18n";
import { SITE_NAVIGATIONS } from "@/v2/constants/site-navigations";

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = await createTranslator(locale);
---

<nav
  id="navbar"
  class="bg-navbar border-border px-content-edges [&.scrolled]:bg-navbar-scrolled] fixed top-0 right-0 left-0 z-1000 flex items-center justify-between border-b py-5 backdrop-blur-xs transition-all duration-500 ease-in-out [&.scrolled]:backdrop-blur-md [&.visible]:opacity-100"
>
  <a href={getLocalizedPath(locale, "/")} class="block leading-none">
    <LogoLong class="block h-[26px] w-auto" />
  </a>

  <ul
    class="nav-links absolute left-1/2 hidden -translate-x-1/2 list-none gap-8 md:flex"
  >
    {
      SITE_NAVIGATIONS.map((item) => (
        <li>
          <a
            href={item.href}
            class="after:bg-whitepaper-primary relative text-[12px] font-normal tracking-[0.09em] text-(--muted) uppercase no-underline transition-all duration-200 ease-in-out after:absolute after:bottom-[-2px] after:left-0 after:h-px after:w-0 after:transition-all after:duration-250 after:content-[''] hover:text-white hover:opacity-100 hover:after:w-full [&.nav-active]:text-white [&.nav-active]:after:bottom-[-4px] [&.nav-active]:after:h-[2px] [&.nav-active]:after:w-full"
          >
            {t(item.label)}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="flex items-center gap-4">
    <a
      href="#"
      class="nav-dl wallet-cta-link hidden border border-(--flare) px-[18px] py-2 font-mono text-[10.5px] font-medium tracking-[0.12em] text-(--flare) uppercase no-underline transition-all duration-180 hover:bg-(--flare) hover:text-(--void) md:block"
      target="_blank"
      rel="noopener">Download Wallet</a
    >
    <button
      class="nav-hamburger group flex h-9 w-9 cursor-pointer items-center justify-center border-none bg-none p-1 md:hidden"
      id="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg
        class="hamburger-icon group-[.open]:hidden"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="3"
          y1="6"
          x2="21"
          y2="6"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="3"
          y1="12"
          x2="21"
          y2="12"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="3"
          y1="18"
          x2="21"
          y2="18"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
      </svg>
      <svg
        class="close-icon hidden group-[.open]:block"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="4"
          y1="4"
          x2="20"
          y2="20"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
        <line
          x1="20"
          y1="4"
          x2="4"
          y2="20"
          stroke="#E8E6E0"
          stroke-width="1.5"
          stroke-linecap="square"></line>
      </svg>
    </button>
  </div>

  <div
    class="mobile-menu fixed inset-0 z-999 hidden flex-col items-center justify-center gap-8 bg-(--void) p-8"
    id="mobile-nav-menu"
  >
    <div class="mobile-menu-links flex flex-col items-center gap-6">
      {
        SITE_NAVIGATIONS.map((item) => (
          <a
            href={item.href}
            class="text-lg font-medium tracking-widest text-(--content) uppercase"
          >
            {t(item.label)}
          </a>
        ))
      }
    </div>
    <a
      href="#"
      class="mobile-menu-cta wallet-cta-link border border-(--flare) px-8 py-4 font-mono text-sm font-medium tracking-widest text-(--flare) uppercase no-underline transition-all hover:bg-(--flare) hover:text-(--void)"
      target="_blank"
      rel="noopener">Download Wallet</a
    >
  </div>
</nav>

<script>
  const hamburger = document.getElementById("nav-hamburger");
  const mobileMenu = document.getElementById("mobile-nav-menu");

  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.classList.add("flex");
    hamburger?.classList.add("open");
    hamburger?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    mobileMenu?.classList.remove("flex");
    hamburger?.classList.remove("open");
    hamburger?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  document.addEventListener("click", (e) => {
    if (
      mobileMenu &&
      !mobileMenu.classList.contains("hidden") &&
      !mobileMenu.contains(e.target as Node) &&
      !hamburger?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  // Scroll: darken background on scroll
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }
  });
</script>
